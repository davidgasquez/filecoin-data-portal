---
import Head from "../components/Head.astro";
import "../styles.css";
---

<!doctype html>
<html lang="en">
    <head>
        <Head
            title="Filecoin Data Portal"
            author="Nexus Data Labs"
            description="Open Data Platform for the Filecoin Ecosystem."
        />
    </head>
    <body>
        <a class="skip-link" href="#main">Skip to content</a>

        <header class="site-header">
            <div class="site-header-inner">
                <a class="brand" href="/" aria-label="Filecoin Data Portal home">
                    <img
                        src="/favicon.svg"
                        alt=""
                        width="56"
                        height="56"
                        loading="eager"
                    />
                    <span>Filecoin Data Portal</span>
                </a>

                <nav aria-label="Primary">
                    <ul class="nav-list">
                        <li><a href="/">Home</a></li>
                        <li><a href="/about">About</a></li>
                        <li><a href="/data">Data</a></li>
                        <li><a href="/dashboards">Dashboards</a></li>
                        <li><a href="/docs">Documentation</a></li>
                    </ul>
                </nav>
            </div>
        </header>

        <main id="main" class="site-main">
            <slot />
        </main>

        <footer class="site-footer">
            <p>
                <a href="https://davidgasquez.com/">Reach Out</a> or explore the
                <a href="https://github.com/davidgasquez/filecoin-data-portal"
                    >project's code</a
                >.
            </p>
        </footer>
    </body>
</html>
