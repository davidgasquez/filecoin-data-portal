---
type LineChartFormat =
  | "integer"
  | "number"
  | "pib"
  | "tib"
  | "fil"
  | "mfil"
  | "usdfc"
  | "usd"
  | "percent"

interface Props {
  id: string
  title: string
  x: string
  y: string
  format?: LineChartFormat
  showMovingAverage?: boolean
  movingAverageWindowDays?: number
}

const {
  id,
  title,
  x,
  y,
  format = "number",
  showMovingAverage = false,
  movingAverageWindowDays = 30,
} = Astro.props
---

<article
  class="line-chart"
  data-line-chart
  data-chart-id={id}
  data-x={x}
  data-y={y}
  data-format={format}
  data-show-moving-average={String(showMovingAverage)}
  data-moving-average-window-days={String(movingAverageWindowDays)}
>
  <div class="line-chart__title-row">
    <h3>{title}</h3>
    <span class="line-chart__headline" data-line-chart-last-value hidden></span>
  </div>

  <div class="line-chart__canvas">
    <svg class="line-chart__svg" aria-hidden="true"></svg>
    <p class="line-chart__empty" hidden>No data available for this range.</p>
    <div class="line-chart__tooltip" hidden></div>
  </div>
</article>
