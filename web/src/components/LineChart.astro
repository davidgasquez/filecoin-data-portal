---
interface Props {
  title: string
  metricKey:
    | "sector_onboarding_raw_power_pibs"
    | "clients_with_active_data_gt_1_tibs"
    | "deal_storage_cost_fil"
    | "total_value_flow_fil"
  yLabel: string
  format: "pib" | "integer" | "fil" | "mfil"
}

const { title, metricKey, yLabel, format } = Astro.props
---

<article
  class="line-chart"
  data-kpi-chart
  data-metric-key={metricKey}
  data-format={format}
>
  <header class="line-chart__header">
    <h3>{title}</h3>
    <p>{yLabel}</p>
  </header>

  <div class="line-chart__canvas">
    <svg class="line-chart__svg" aria-hidden="true"></svg>
    <p class="line-chart__empty" hidden>No data available for this range.</p>
    <div class="line-chart__tooltip" hidden></div>
  </div>
</article>

<script>
  import compactDataset from "../data/generated/filecoin-daily-kpis.json"

  type ParsedKpiRow = {
    timestamp: number
    sector_onboarding_raw_power_pibs: number
    clients_with_active_data_gt_1_tibs: number
    deal_storage_cost_fil: number
    total_value_flow_fil: number
  }

  type CompactKpiDataset = {
    s: string
    r: Array<[number, number, number, number, number]>
  }

  type RangeType = "1y" | "all"

  const CHART_SELECTOR = "[data-kpi-chart]"
  const RANGE_BUTTON_SELECTOR = "[data-kpi-range]"

  const chartNodes = Array.from(document.querySelectorAll<HTMLElement>(CHART_SELECTOR))

  if (chartNodes.length === 0) {
    throw new Error("No KPI chart containers found")
  }

  const compactRows = compactDataset as CompactKpiDataset
  const startTimestamp = new Date(`${compactRows.s}T00:00:00Z`).getTime()

  const rows: ParsedKpiRow[] = compactRows.r
    .map(([dayOffset, sectorOnboardingMicroPibs, clients, dealStorageCostNanoFil, totalValueFlowMilliFil]) => ({
      timestamp: startTimestamp + dayOffset * 86_400_000,
      sector_onboarding_raw_power_pibs: sectorOnboardingMicroPibs / 1_000_000,
      clients_with_active_data_gt_1_tibs: clients,
      deal_storage_cost_fil: dealStorageCostNanoFil / 1_000_000_000,
      total_value_flow_fil: totalValueFlowMilliFil / 1_000,
    }))
    .sort((a, b) => a.timestamp - b.timestamp)

  if (rows.length === 0) {
    throw new Error("KPI dataset is empty")
  }

  let currentRange: RangeType = "1y"

  const tooltipDateFormatter = new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  })

  function formatValue(value: number, format: string): string {
    if (format === "integer") {
      return Math.round(value).toLocaleString("en-US")
    }

    if (format === "pib") {
      return `${value.toLocaleString("en-US", {
        maximumFractionDigits: 2,
      })} PiB`
    }

    if (format === "mfil") {
      return `${(value / 1e6).toLocaleString("en-US", {
        maximumFractionDigits: 2,
      })} M FIL`
    }

    return `${value.toLocaleString("en-US", {
      maximumFractionDigits: 2,
    })} FIL`
  }

  function formatTickValue(value: number, format: string): string {
    if (format === "integer") {
      return Math.round(value).toLocaleString("en-US")
    }

    if (format === "mfil") {
      return `${(value / 1e6).toLocaleString("en-US", {
        maximumFractionDigits: 1,
      })}M`
    }

    if (format === "fil") {
      return value.toLocaleString("en-US", {
        maximumFractionDigits: 0,
      })
    }

    return value.toLocaleString("en-US", {
      maximumFractionDigits: 2,
    })
  }

  function getRowsForRange(range: RangeType): ParsedKpiRow[] {
    if (range === "all") {
      return rows
    }

    const latestTimestamp = rows[rows.length - 1].timestamp
    const latestDate = new Date(latestTimestamp)
    const oneYearAgo = new Date(
      Date.UTC(
        latestDate.getUTCFullYear() - 1,
        latestDate.getUTCMonth(),
        latestDate.getUTCDate(),
      ),
    ).getTime()

    return rows.filter((row) => row.timestamp >= oneYearAgo)
  }

  function findClosestPointIndex(points: { x: number; y: number }[], x: number): number {
    if (points.length === 1) {
      return 0
    }

    let left = 0
    let right = points.length - 1

    while (left < right) {
      const mid = Math.floor((left + right) / 2)
      if (points[mid].x < x) {
        left = mid + 1
      } else {
        right = mid
      }
    }

    const rightCandidate = left
    const leftCandidate = Math.max(0, rightCandidate - 1)

    return Math.abs(points[rightCandidate].x - x) <
      Math.abs(points[leftCandidate].x - x)
      ? rightCandidate
      : leftCandidate
  }

  function buildTicks(min: number, max: number, count: number): number[] {
    if (count < 2) {
      return [min]
    }

    const step = (max - min) / (count - 1)
    return Array.from({ length: count }, (_, index) => min + index * step)
  }

  function updateRangeButtons(range: RangeType): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

    for (const button of buttons) {
      const buttonRange = button.dataset.kpiRange as RangeType
      const isActive = buttonRange === range
      button.setAttribute("aria-pressed", String(isActive))
    }
  }

  function renderChart(node: HTMLElement, filteredRows: ParsedKpiRow[]): void {
    const metricKey = node.dataset.metricKey as keyof ParsedKpiRow
    const format = node.dataset.format ?? "integer"

    const svg = node.querySelector<SVGElement>(".line-chart__svg")
    const tooltip = node.querySelector<HTMLDivElement>(".line-chart__tooltip")
    const emptyMessage = node.querySelector<HTMLParagraphElement>(".line-chart__empty")

    if (!svg || !tooltip || !emptyMessage) {
      throw new Error("Line chart markup is incomplete")
    }

    const width = Math.max(360, node.clientWidth)
    const height = 300
    const margin = { top: 12, right: 12, bottom: 36, left: 74 }
    const plotWidth = width - margin.left - margin.right
    const plotHeight = height - margin.top - margin.bottom

    const series = filteredRows
      .map((row) => ({
        timestamp: row.timestamp,
        value: Number(row[metricKey]),
      }))
      .filter((row) => Number.isFinite(row.value))

    if (series.length < 2) {
      svg.innerHTML = ""
      emptyMessage.hidden = false
      tooltip.hidden = true
      return
    }

    emptyMessage.hidden = true

    const minX = series[0].timestamp
    const maxX = series[series.length - 1].timestamp

    let minY = Math.min(...series.map((point) => point.value))
    let maxY = Math.max(...series.map((point) => point.value))

    if (minY === maxY) {
      minY -= 1
      maxY += 1
    }

    const yPadding = (maxY - minY) * 0.08
    minY -= yPadding
    maxY += yPadding

    const scaleX = (value: number): number =>
      margin.left + ((value - minX) / (maxX - minX)) * plotWidth

    const scaleY = (value: number): number =>
      margin.top + ((maxY - value) / (maxY - minY)) * plotHeight

    const points = series.map((point) => ({
      ...point,
      x: scaleX(point.timestamp),
      y: scaleY(point.value),
    }))

    const path = points
      .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
      .join(" ")

    const rangeDays = Math.round((maxX - minX) / 86_400_000)
    const xTickDateFormatter = new Intl.DateTimeFormat("en-US", {
      month: "short",
      ...(rangeDays > 500 ? { year: "2-digit" } : { day: "numeric", year: "2-digit" }),
      timeZone: "UTC",
    })

    const yTicks = buildTicks(minY, maxY, 5)
    const xTicks = buildTicks(minX, maxX, 5)

    const yTickMarkup = yTicks
      .map((tick) => {
        const y = scaleY(tick)

        return `
          <line x1="${margin.left}" y1="${y}" x2="${width - margin.right}" y2="${y}" class="line-chart__gridline" />
          <text x="${margin.left - 8}" y="${y + 3}" text-anchor="end" class="line-chart__label">${formatTickValue(tick, format)}</text>
        `
      })
      .join("")

    const xTickMarkup = xTicks
      .map((tick) => {
        const x = scaleX(tick)

        return `
          <line x1="${x}" y1="${margin.top}" x2="${x}" y2="${height - margin.bottom}" class="line-chart__gridline line-chart__gridline--vertical" />
          <text x="${x}" y="${height - 8}" text-anchor="middle" class="line-chart__label">${xTickDateFormatter.format(new Date(tick))}</text>
        `
      })
      .join("")

    svg.setAttribute("viewBox", `0 0 ${width} ${height}`)
    svg.innerHTML = `
      ${yTickMarkup}
      ${xTickMarkup}
      <line x1="${margin.left}" y1="${margin.top}" x2="${margin.left}" y2="${height - margin.bottom}" class="line-chart__axis" />
      <line x1="${margin.left}" y1="${height - margin.bottom}" x2="${width - margin.right}" y2="${height - margin.bottom}" class="line-chart__axis" />
      <path d="${path}" class="line-chart__path" />
      <line x1="0" y1="0" x2="0" y2="0" class="line-chart__crosshair" visibility="hidden" />
      <circle cx="0" cy="0" r="4" class="line-chart__dot" visibility="hidden" />
      <rect x="${margin.left}" y="${margin.top}" width="${plotWidth}" height="${plotHeight}" class="line-chart__overlay" />
    `

    const crosshair = svg.querySelector<SVGLineElement>(".line-chart__crosshair")
    const dot = svg.querySelector<SVGCircleElement>(".line-chart__dot")
    const overlay = svg.querySelector<SVGRectElement>(".line-chart__overlay")

    if (!crosshair || !dot || !overlay) {
      throw new Error("Line chart interactive layer could not be initialized")
    }

    const hideTooltip = (): void => {
      crosshair.setAttribute("visibility", "hidden")
      dot.setAttribute("visibility", "hidden")
      tooltip.hidden = true
    }

    const showTooltip = (clientX: number): void => {
      const rect = svg.getBoundingClientRect()
      const pointerX = ((clientX - rect.left) / rect.width) * width

      if (pointerX < margin.left || pointerX > width - margin.right) {
        hideTooltip()
        return
      }

      const closestPointIndex = findClosestPointIndex(points, pointerX)
      const point = points[closestPointIndex]

      crosshair.setAttribute("x1", String(point.x))
      crosshair.setAttribute("y1", String(margin.top))
      crosshair.setAttribute("x2", String(point.x))
      crosshair.setAttribute("y2", String(height - margin.bottom))
      crosshair.setAttribute("visibility", "visible")

      dot.setAttribute("cx", String(point.x))
      dot.setAttribute("cy", String(point.y))
      dot.setAttribute("visibility", "visible")

      tooltip.textContent = `${tooltipDateFormatter.format(new Date(point.timestamp))} · ${formatValue(point.value, format)}`
      tooltip.hidden = false

      const tooltipPadding = 10
      const tooltipHalfWidth = tooltip.offsetWidth / 2
      const minLeft = tooltipPadding
      const maxLeft = width - tooltip.offsetWidth - tooltipPadding

      const tooltipLeft = Math.min(maxLeft, Math.max(minLeft, point.x - tooltipHalfWidth))
      const tooltipTop = Math.max(tooltipPadding, point.y - 34)

      tooltip.style.left = `${tooltipLeft}px`
      tooltip.style.top = `${tooltipTop}px`
    }

    overlay.addEventListener("pointermove", (event) => {
      showTooltip(event.clientX)
    })

    overlay.addEventListener("mousemove", (event) => {
      showTooltip(event.clientX)
    })

    overlay.addEventListener("touchstart", (event) => {
      const touch = event.touches[0]
      if (touch) {
        showTooltip(touch.clientX)
      }
    }, { passive: true })

    overlay.addEventListener("touchmove", (event) => {
      const touch = event.touches[0]
      if (touch) {
        showTooltip(touch.clientX)
      }
    }, { passive: true })

    overlay.addEventListener("pointerleave", hideTooltip)
    overlay.addEventListener("mouseleave", hideTooltip)
    overlay.addEventListener("touchend", hideTooltip)
  }

  function renderAllCharts(): void {
    const filteredRows = getRowsForRange(currentRange)

    for (const chartNode of chartNodes) {
      renderChart(chartNode, filteredRows)
    }
  }

  const observers = chartNodes.map((chartNode) => {
    const observer = new ResizeObserver(() => {
      renderChart(chartNode, getRowsForRange(currentRange))
    })

    observer.observe(chartNode)
    return observer
  })

  const rangeButtons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

  for (const button of rangeButtons) {
    button.addEventListener("click", () => {
      const range = button.dataset.kpiRange as RangeType

      if (range === currentRange) {
        return
      }

      currentRange = range
      updateRangeButtons(currentRange)
      renderAllCharts()
    })
  }

  updateRangeButtons(currentRange)
  renderAllCharts()

  window.addEventListener("beforeunload", () => {
    for (const observer of observers) {
      observer.disconnect()
    }
  })
</script>
