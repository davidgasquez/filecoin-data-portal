---
import type { ChartConfig, NumbersMetric } from "../types/numbers"

const { id, title, description, details, y, format, scale, suffix, series } =
  Astro.props as NumbersMetric

const serializeChart = (config: ChartConfig) => JSON.stringify(config)

const chartConfig = serializeChart({ y, format, scale, suffix, series })
const tooltipId = `${id}-description`
---

<figure class="stat-card" data-stat-card data-chart={chartConfig} data-chart-id={id}>
  <figcaption class="stat-card__header">
    <a href={`#${id}`} id={id} class="stat-card__label" data-chart-title>{title}</a>
    <span class="stat-card__headline" data-chart-headline></span>
    <button
      type="button"
      class="stat-card__info"
      aria-label={`About ${title}`}
      aria-describedby={tooltipId}
    >
      i
      <span id={tooltipId} class="stat-card__info-tooltip" role="tooltip">{description}</span>
    </button>
    <button
      type="button"
      class="stat-card__toggle"
      data-chart-toggle
      aria-expanded="false"
      aria-label={`Expand ${title}`}
      title={`Expand ${title}`}
    >
      +
    </button>
  </figcaption>

  <strong class="stat-card__value" data-chart-value></strong>
  <span class="stat-card__trend" data-chart-trend></span>
  <p class="stat-card__description">{description}</p>
  <div
    class="stat-card__chart"
    data-chart-canvas
    role="img"
    aria-label={`${title} trend chart`}
  ></div>

  {details && (
    <div class="stat-card__details">
      <div class="stat-card__detail-grid">
        {details.map(({ title: detailTitle, description: detailDescription, ...config }) => (
          <div class="stat-card__detail" data-detail-chart data-chart={serializeChart(config)}>
            <header class="stat-card__detail-header">
              <span>{detailTitle}</span>
              <strong data-detail-value></strong>
            </header>
            <p>{detailDescription}</p>
            <div
              class="stat-card__detail-chart"
              data-chart-canvas
              role="img"
              aria-label={`${detailTitle} trend chart`}
            ></div>
          </div>
        ))}
      </div>
    </div>
  )}
</figure>
