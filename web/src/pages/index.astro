---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
---

<Layout>
    <header class="hero">
        <h1>Filecoin Data Portal</h1>

        <p>
            Open source, serverless, and local-first Data Platform for the
            Filecoin ecosystem.
        </p>
    </header>

    <section class="home-sections" aria-labelledby="home-sections-title">
        <h2 id="home-sections-title">Explore</h2>

        <div class="card-grid">
            <Card
                title="Open Data"
                description="Download Filecoin datasets with key metrics and entities."
                buttons={[{ text: "Get Datasets", link: "/data" }]}
            />
            <Card
                title="Dashboards"
                description="Explore dashboards with key metrics from the Filecoin ecosystem."
                buttons={[{ text: "Explore", link: "/dashboards" }]}
            />
            <Card
                title="Data Requests"
                description="Need specific data? Want some metric reflected? Let's chat!"
                buttons={[
                    {
                        text: "Request Dataset",
                        link: "https://github.com/davidgasquez/filecoin-data-portal/issues/new",
                    },
                ]}
            />
            <Card
                title="Support on Drips"
                description="Support the data platform development via Drips."
                buttons={[
                    {
                        text: "Support",
                        link: "https://www.drips.network/app/projects/github/davidgasquez/filecoin-data-portal",
                    },
                ]}
            />
        </div>
    </section>
</Layout>

<style>
    .hero {
        text-align: center;
        padding: var(--space-4) 0;
    }

    .hero p {
        margin-left: auto;
        margin-right: auto;
    }

    .home-sections h2 {
        margin-top: 0;
    }
</style>
