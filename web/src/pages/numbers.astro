        format: "usd",
      },
      {
        id: "fil-token-volume",
        title: "FIL Token Volume",
        y: "fil_token_volume_usd",
        format: "usd",
        formatScale: 1_000_000,
        formatSuffix: "M",
      },
      {
        id: "fil-token-market-cap",
        title: "FIL Token Market Cap",
        y: "fil_token_market_cap_usd",
        format: "usd",
        formatScale: 1_000_000_000,
        formatSuffix: "B",
      },
      {
        id: "fil-plus-bytes-share",
        title: "Filecoin Plus Bytes Share",
        y: "fil_plus_bytes_share",
        format: "percent",
      },
      {
        id: "fil-plus-rewards-share",
        title: "Filecoin Plus Rewards Share",
        y: "fil_plus_rewards_share",
        format: "percent",
      },
    ],
  },
