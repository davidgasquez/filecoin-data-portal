---

<Layout
  title="Filecoin in Numbers | Filecoin Data Portal"
  description="Core Filecoin metrics with interactive charts for KPIs, sectors, power, activity, state market deals, and economics."
>
  <div class="numbers-toolbar">
    <h1>Filecoin in Numbers</h1>
    <div class="chart-range-toggle" role="group" aria-label="Chart timeframe">
      <button type="button" data-line-chart-range="6m" aria-pressed="false">6M</button>
      <button type="button" data-line-chart-range="1y" aria-pressed="true">1Y</button>
      <button type="button" data-line-chart-range="all" aria-pressed="false">All</button>
    </div>
  </div>

  {
    sections.map((section) => (
      <section class="numbers-section" aria-labelledby={section.id}>
        <h2 id={section.id} class="numbers-section__legend">{section.title}</h2>

        <div class="card-grid card-grid--two-up">
          {
            section.charts.map((chart) => (
              <LineChart
                id={chart.id}
                title={chart.title}
                x={chartX}
                y={chart.y}
                format={chart.format}
                formatScale={chart.formatScale}
                formatPrefix={chart.formatPrefix}
                formatSuffix={chart.formatSuffix}
                percentMode={chart.percentMode}
                showMovingAverage={true}
                movingAverageWindowDays={30}
              />
            ))
          }
        </div>
      </section>
    ))
  }

  <script
    type="application/json"
    is:inline
    data-numbers-dataset
    set:html={serializedDailyMetrics}
  ></script>

  <script>
    type DatasetRowValue = string | number | null
    type DatasetRow = Record<string, DatasetRowValue>

    type LineChartPoint = {
      timestamp: number
      value: number
    }

    type LineChartFormat =
      | "integer"
      | "number"
      | "pib"
      | "tib"
      | "fil"
      | "mfil"
      | "usdfc"
      | "usd"
      | "percent"

    type PercentMode = "fraction" | "points"

    type RangeType = "6m" | "1y" | "all"

    type ParsedChart = {
      id: string
      node: HTMLElement
      data: LineChartPoint[]
      format: LineChartFormat
      formatScale: number
      formatPrefix: string
      formatSuffix: string
      percentMode: PercentMode
      showMovingAverage: boolean
      movingAverageWindowDays: number
    }

    const DATASET_SELECTOR = "[data-numbers-dataset]"
    const CHART_SELECTOR = "[data-line-chart]"
    const RANGE_BUTTON_SELECTOR = "[data-line-chart-range]"
    const CHART_HEIGHT = 240
    const CHART_MARGIN = { top: 22, right: 10, bottom: 28, left: 10 }
    const DAY_IN_MS = 86_400_000

    const chartNodes = Array.from(document.querySelectorAll<HTMLElement>(CHART_SELECTOR))

    if (chartNodes.length > 0) {
      const dataset = parseDataset()
      const charts = chartNodes.map((node) => parseChart(node, dataset))
      let currentRange = getInitialRange()

      const tooltipDateFormatter = new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
        timeZone: "UTC",
      })

      function parseDataset(): DatasetRow[] {
        const datasetScript = document.querySelector<HTMLScriptElement>(DATASET_SELECTOR)

        if (!datasetScript?.textContent) {
          throw new Error("Numbers dataset is missing")
        }

        const rawDataset = JSON.parse(datasetScript.textContent) as unknown

        if (!Array.isArray(rawDataset)) {
          throw new Error("Numbers dataset must be an array")
        }

        return rawDataset as DatasetRow[]
      }

      function parseChart(node: HTMLElement, rows: DatasetRow[]): ParsedChart {
        const chartId = node.dataset.chartId
        const x = node.dataset.x
        const y = node.dataset.y

        if (!chartId || !x || !y) {
          throw new Error("Line chart is missing required dataset attributes")
        }

        return {
          id: chartId,
          node,
          data: rows
            .map((row, rowIndex) => toPoint(chartId, row, x, y, rowIndex))
            .filter((point): point is LineChartPoint => point !== null)
            .sort((left, right) => left.timestamp - right.timestamp),
          format: parseFormat(node.dataset.format),
          formatScale: parsePositiveNumber(node.dataset.formatScale, 1),
          formatPrefix: node.dataset.formatPrefix ?? "",
          formatSuffix: node.dataset.formatSuffix ?? "",
          percentMode: parsePercentMode(node.dataset.percentMode),
          showMovingAverage: node.dataset.showMovingAverage === "true",
          movingAverageWindowDays: parsePositiveInteger(
            node.dataset.movingAverageWindowDays,
            30,
          ),
        }
      }

      function toPoint(
        chartId: string,
        row: DatasetRow,
        x: string,
        y: string,
        rowIndex: number,
      ): LineChartPoint | null {
        const rawTimestamp = row[x]
        const rawValue = row[y]

        if (rawTimestamp == null || rawValue == null) {
          return null
        }

        const timestamp = toTimestamp(chartId, x, rawTimestamp)
        const value = Number(rawValue)

        if (!Number.isFinite(value)) {
          throw new Error(`Line chart ${chartId} row ${rowIndex} has an invalid y value for ${y}`)
        }

        return { timestamp, value }
      }

      function toTimestamp(chartId: string, x: string, value: DatasetRowValue): number {
        if (typeof value === "number" && Number.isFinite(value)) {
          return value
        }

        if (typeof value === "string") {
          const timestamp = new Date(value).getTime()

          if (Number.isFinite(timestamp)) {
            return timestamp
          }
        }

        throw new Error(`Line chart ${chartId} has an invalid x value for ${x}: ${String(value)}`)
      }

      function parseFormat(value: string | undefined): LineChartFormat {
        switch (value) {
          case "integer":
          case "number":
          case "pib":
          case "tib":
          case "fil":
          case "mfil":
          case "usdfc":
          case "usd":
          case "percent":
            return value
          case undefined:
            return "number"
          default:
            throw new Error(`Unsupported line chart format: ${value}`)
        }
      }

      function parsePositiveInteger(value: string | undefined, fallback: number): number {
        const parsed = Number(value)

        if (!Number.isInteger(parsed) || parsed <= 0) {
          return fallback
        }

        return parsed
      }

      function parsePositiveNumber(value: string | undefined, fallback: number): number {
        const parsed = Number(value)

        if (!Number.isFinite(parsed) || parsed <= 0) {
          return fallback
        }

        return parsed
      }

      function parsePercentMode(value: string | undefined): PercentMode {
        if (value === "points") {
          return value
        }

        return "fraction"
      }

      function getInitialRange(): RangeType {
        const activeButton = document.querySelector<HTMLButtonElement>(
          `${RANGE_BUTTON_SELECTOR}[aria-pressed="true"]`,
        )

        const range = activeButton?.dataset.lineChartRange
        if (range === "6m" || range === "all") return range
        return "1y"
      }

      function formatDecimal(value: number, maximumFractionDigits: number): string {
        return value.toLocaleString("en-US", {
          maximumFractionDigits,
        })
      }

      function formatUsd(value: number, maximumFractionDigits: number): string {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          maximumFractionDigits,
        }).format(value)
      }

      function scaleDisplayValue(value: number, scale: number): number {
        return value / scale
      }

      function formatValue(
        value: number,
        chart: Pick<ParsedChart, "format" | "formatScale" | "formatPrefix" | "formatSuffix" | "percentMode">,
        context: "headline" | "tick" | "tooltip",
      ): string {
        const maximumFractionDigits = context === "tick" ? 1 : 2
        const scaledValue = scaleDisplayValue(value, chart.formatScale)

        if (chart.format === "integer") {
          return `${chart.formatPrefix}${Math.round(scaledValue).toLocaleString("en-US")}${chart.formatSuffix}`
        }

        if (chart.format === "mfil") {
          const millionsValue = scaledValue / 1_000_000
          const suffix = context === "tick" ? `M${chart.formatSuffix}` : ` M FIL${chart.formatSuffix}`
          return `${chart.formatPrefix}${formatDecimal(millionsValue, context === "tick" ? 1 : 2)}${suffix}`
        }

        if (chart.format === "usd") {
          return `${chart.formatPrefix}${formatUsd(scaledValue, context === "tick" ? 0 : 2)}${chart.formatSuffix}`
        }

        if (chart.format === "percent") {
          const percentValue = chart.percentMode === "fraction" ? scaledValue * 100 : scaledValue
          const percentFractionDigits = context === "tick" ? 0 : 2
          return `${chart.formatPrefix}${formatDecimal(percentValue, percentFractionDigits)}%${chart.formatSuffix}`
        }

        const suffixByFormat = {
          number: "",
          pib: " PiB",
          tib: " TiB",
          fil: " FIL",
          usdfc: " USDFC",
        } satisfies Record<Exclude<LineChartFormat, "integer" | "mfil" | "usd" | "percent">, string>

        return `${chart.formatPrefix}${formatDecimal(scaledValue, maximumFractionDigits)}${suffixByFormat[chart.format]}${chart.formatSuffix}`
      }

      function getPointsForRange(points: LineChartPoint[], range: RangeType): LineChartPoint[] {
        if (range === "all") {
          return points
        }

        const latestTimestamp = points[points.length - 1]?.timestamp

        if (latestTimestamp == null) {
          return []
        }

        const latestDate = new Date(latestTimestamp)
        const monthsBack = range === "6m" ? 6 : 12
        const cutoff = new Date(
          Date.UTC(
            latestDate.getUTCFullYear(),
            latestDate.getUTCMonth() - monthsBack,
            latestDate.getUTCDate(),
          ),
        ).getTime()

        return points.filter((point) => point.timestamp >= cutoff)
      }

      function findClosestPointIndex(points: { x: number }[], x: number): number {
        if (points.length === 1) {
          return 0
        }

        let left = 0
        let right = points.length - 1

        while (left < right) {
          const mid = Math.floor((left + right) / 2)

          if (points[mid].x < x) {
            left = mid + 1
          } else {
            right = mid
          }
        }

        const rightCandidate = left
        const leftCandidate = Math.max(0, rightCandidate - 1)

        return Math.abs(points[rightCandidate].x - x) <
          Math.abs(points[leftCandidate].x - x)
          ? rightCandidate
          : leftCandidate
      }

      function buildMovingAverage(values: number[], windowSize: number): number[] {
        if (windowSize < 1) {
          throw new Error("Moving average window size must be greater than zero")
        }

        let runningTotal = 0

        return values.map((value, index) => {
          runningTotal += value

          if (index >= windowSize) {
            runningTotal -= values[index - windowSize]
          }

          const sampleSize = Math.min(windowSize, index + 1)
          return runningTotal / sampleSize
        })
      }

      function buildTicks(min: number, max: number, count: number): number[] {
        if (count < 2) {
          return [min]
        }

        const step = (max - min) / (count - 1)
        return Array.from({ length: count }, (_, index) => min + index * step)
      }

      function updateRangeButtons(range: RangeType): void {
        const buttons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

        for (const button of buttons) {
          const isActive = button.dataset.lineChartRange === range
          button.setAttribute("aria-pressed", String(isActive))
        }
      }

      function setupHeadlineTip(
        chartNode: HTMLElement,
        trigger: HTMLElement,
        text: string,
      ): void {
        const tip = chartNode.querySelector<HTMLElement>("[data-line-chart-headline-tip]")

        if (!tip) {
          return
        }

        if (!text) {
          tip.hidden = true
          trigger.removeAttribute("data-has-tip")
          return
        }

        tip.innerHTML = text
        trigger.setAttribute("data-has-tip", "")

        trigger.onmouseenter = () => {
          tip.hidden = false
        }

        trigger.onmouseleave = () => {
          tip.hidden = true
        }
      }

      function renderChart(chart: ParsedChart): void {
        const filteredData = getPointsForRange(chart.data, currentRange)

        const svg = chart.node.querySelector<SVGElement>(".line-chart__svg")
        const tooltip = chart.node.querySelector<HTMLDivElement>(".line-chart__tooltip")
        const emptyMessage = chart.node.querySelector<HTMLParagraphElement>(".line-chart__empty")
        const headlineValue = chart.node.querySelector<HTMLSpanElement>("[data-line-chart-last-value]")

        if (!svg || !tooltip || !emptyMessage || !headlineValue) {
          throw new Error(`Line chart ${chart.id} markup is incomplete`)
        }

        const width = Math.max(320, chart.node.clientWidth)
        const height = CHART_HEIGHT
        const margin = CHART_MARGIN
        const plotWidth = width - margin.left - margin.right
        const plotHeight = height - margin.top - margin.bottom

        if (filteredData.length < 2) {
          svg.innerHTML = ""
          emptyMessage.hidden = false
          tooltip.hidden = true
          tooltip.textContent = ""
          headlineValue.hidden = true
          headlineValue.textContent = ""
          return
        }

        emptyMessage.hidden = true

        const minX = filteredData[0].timestamp
        const maxX = filteredData[filteredData.length - 1].timestamp
        const rawValues = filteredData.map((point) => point.value)
        const displayValues = chart.showMovingAverage
          ? buildMovingAverage(rawValues, chart.movingAverageWindowDays)
          : rawValues

        const dataMinY = Math.min(...rawValues)
        const dataMaxY = Math.max(...rawValues)
        const startsAtZero = dataMinY >= 0
        const minY = startsAtZero ? 0 : dataMinY
        let maxY = dataMaxY

        if (maxY === minY) {
          maxY = minY + 1
        }

        maxY += (maxY - minY) * 0.08

        const scaleX = (value: number): number =>
          margin.left + ((value - minX) / Math.max(maxX - minX, DAY_IN_MS)) * plotWidth

        const scaleY = (value: number): number =>
          margin.top + ((maxY - value) / (maxY - minY)) * plotHeight

        const rawPoints = filteredData.map((point) => ({
          ...point,
          x: scaleX(point.timestamp),
          y: scaleY(point.value),
        }))

        const points = filteredData.map((point, index) => ({
          timestamp: point.timestamp,
          rawValue: point.value,
          value: displayValues[index],
          x: scaleX(point.timestamp),
          y: scaleY(displayValues[index]),
        }))

        const latestPoint = points[points.length - 1]

        if (chart.showMovingAverage) {
          const compareIndex = Math.max(0, points.length - 1 - chart.movingAverageWindowDays)
          const prevValue = points[compareIndex].value
          const trend = latestPoint.value > prevValue ? "▲" : latestPoint.value < prevValue ? "▼" : "■"
          const now = formatValue(latestPoint.value, chart, "tooltip")
          const ago = formatValue(prevValue, chart, "tooltip")

          headlineValue.textContent = `${formatValue(latestPoint.value, chart, "headline")} ${trend}`
          setupHeadlineTip(
            chart.node,
            headlineValue,
            `<span class="tip-row"><span>Now</span><span class="tip-dots"></span><span>${now}</span></span>` +
            `<span class="tip-row"><span>30 Days Ago</span><span class="tip-dots"></span><span>${ago}</span></span>`,
          )
        } else {
          headlineValue.textContent = formatValue(latestPoint.value, chart, "headline")
          setupHeadlineTip(chart.node, headlineValue, "")
        }

        headlineValue.hidden = false

        const rawPath = rawPoints
          .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
          .join(" ")

        const displayPath = points
          .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
          .join(" ")

        const rangeDays = Math.round((maxX - minX) / DAY_IN_MS)
        const xTickDateFormatter = new Intl.DateTimeFormat("en-US", {
          month: "short",
          ...(rangeDays > 500 ? { year: "2-digit" } : { day: "numeric", year: "2-digit" }),
          timeZone: "UTC",
        })

        const yTicks = buildTicks(minY, maxY, 4)
        const xTicks = buildTicks(minX, maxX, 4)

        const yTickMarkup = yTicks
          .map((tick) => {
            const y = scaleY(tick)

            return `
              <line x1="${margin.left}" y1="${y}" x2="${width - margin.right}" y2="${y}" class="line-chart__gridline" />
              <text x="${margin.left + 4}" y="${y - 4}" text-anchor="start" class="line-chart__label">${formatValue(tick, chart, "tick")}</text>
            `
          })
          .join("")

        const xTickMarkup = xTicks
          .map((tick, index) => {
            const x = scaleX(tick)
            const anchor = index === 0 ? "start" : index === xTicks.length - 1 ? "end" : "middle"

            return `
              <text x="${x}" y="${height - 6}" text-anchor="${anchor}" class="line-chart__label">${xTickDateFormatter.format(new Date(tick))}</text>
            `
          })
          .join("")

        const pathMarkup = chart.showMovingAverage
          ? `
            <path d="${rawPath}" class="line-chart__path line-chart__path--raw" />
            <path d="${displayPath}" class="line-chart__path line-chart__path--average" />
          `
          : `<path d="${displayPath}" class="line-chart__path" />`

        svg.setAttribute("viewBox", `0 0 ${width} ${height}`)
        svg.innerHTML = `
          ${yTickMarkup}
          ${xTickMarkup}
          ${pathMarkup}
          <line x1="0" y1="0" x2="0" y2="0" class="line-chart__crosshair" visibility="hidden" />
          <circle cx="0" cy="0" r="3" class="line-chart__dot" visibility="hidden" />
          <rect x="${margin.left}" y="${margin.top}" width="${plotWidth}" height="${plotHeight}" class="line-chart__overlay" />
        `

        const crosshair = svg.querySelector<SVGLineElement>(".line-chart__crosshair")
        const dot = svg.querySelector<SVGCircleElement>(".line-chart__dot")
        const overlay = svg.querySelector<SVGRectElement>(".line-chart__overlay")

        if (!crosshair || !dot || !overlay) {
          throw new Error(`Line chart ${chart.id} interactive layer could not be initialized`)
        }

        const hideTooltip = (): void => {
          crosshair.setAttribute("visibility", "hidden")
          dot.setAttribute("visibility", "hidden")
          tooltip.hidden = true
        }

        const showTooltipFromClientX = (clientX: number): void => {
          const rect = svg.getBoundingClientRect()
          const pointerX = ((clientX - rect.left) / rect.width) * width

          if (pointerX < margin.left || pointerX > width - margin.right) {
            hideTooltip()
            return
          }

          const closestPointIndex = findClosestPointIndex(points, pointerX)
          const point = points[closestPointIndex]

          crosshair.setAttribute("x1", String(point.x))
          crosshair.setAttribute("y1", String(margin.top))
          crosshair.setAttribute("x2", String(point.x))
          crosshair.setAttribute("y2", String(height - margin.bottom))
          crosshair.setAttribute("visibility", "visible")

          dot.setAttribute("cx", String(point.x))
          dot.setAttribute("cy", String(point.y))
          dot.setAttribute("visibility", "visible")

          const formattedDate = tooltipDateFormatter.format(new Date(point.timestamp))

          if (chart.showMovingAverage) {
            tooltip.textContent =
              `${formattedDate} · MA${chart.movingAverageWindowDays} ${formatValue(point.value, chart, "tooltip")} · Raw ${formatValue(point.rawValue, chart, "tooltip")}`
          } else {
            tooltip.textContent = `${formattedDate} · ${formatValue(point.value, chart, "tooltip")}`
          }

          tooltip.hidden = false

          const tooltipPadding = 10
          const tooltipHalfWidth = tooltip.offsetWidth / 2
          const minLeft = tooltipPadding
          const maxLeft = width - tooltip.offsetWidth - tooltipPadding
          const tooltipLeft = Math.min(maxLeft, Math.max(minLeft, point.x - tooltipHalfWidth))
          const tooltipTop = Math.max(tooltipPadding, point.y - 28)

          tooltip.style.left = `${tooltipLeft}px`
          tooltip.style.top = `${tooltipTop}px`
        }

        overlay.addEventListener("pointermove", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerdown", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerleave", hideTooltip)
        overlay.addEventListener("pointercancel", hideTooltip)
        overlay.addEventListener("pointerup", (e) => {
          if (e.pointerType === "touch") {
            hideTooltip()
          }
        })
      }

      function renderAllCharts(): void {
        for (const chart of charts) {
          renderChart(chart)
        }
      }

      const observers = charts.map((chart) => {
        const observer = new ResizeObserver(() => {
          renderChart(chart)
        })

        observer.observe(chart.node)
        return observer
      })

      const rangeButtons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

      for (const button of rangeButtons) {
        button.addEventListener("click", () => {
          const range = button.dataset.lineChartRange

          if (range !== "6m" && range !== "1y" && range !== "all") {
            return
          }

          if (range === currentRange) {
            return
          }

          currentRange = range
          updateRangeButtons(currentRange)
          renderAllCharts()
        })
      }

      updateRangeButtons(currentRange)
      renderAllCharts()

      window.addEventListener(
        "pagehide",
        () => {
          for (const observer of observers) {
            observer.disconnect()
          }
        },
        { once: true },
      )
    }
  </script>
</Layout>
