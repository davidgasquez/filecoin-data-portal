---
import dailyMetricsDataset from "../data/generated/filecoin-daily-metrics.json"
import SectionHeading from "../components/SectionHeading.astro"
import StatCard from "../components/StatCard.astro"
import Layout from "../layouts/Layout.astro"
import type { NumbersSection } from "../types/numbers"

type DatasetValue = string | number | null
type DatasetRow = Record<string, DatasetValue>

const dailyMetrics = dailyMetricsDataset as DatasetRow[]

if (dailyMetrics.length === 0) {
  throw new Error("Generated daily metrics dataset is empty")
}

const sections: NumbersSection[] = [
  {
    id: "key-metrics",
    title: "Ecosystem KPIs",
    columns: 3,
    charts: [
      {
        id: "filecoin-pay-gross-payment-volume-run-rate-usd",
        title: "Filecoin Pay Gross Payment Volume Run Rate",
        description: "Annualized gross stablecoin payment volume from active eligible recurring Filecoin Pay rails, including USDFC and USDC.axl, at day-end.",
        y: "filecoin_pay_gross_payment_volume_run_rate_usd",
        format: "usd",
        series: [
          { label: "USDFC", y: "filecoin_pay_gross_payment_volume_run_rate_usdfc_usd" },
          { label: "USDC.axl", y: "filecoin_pay_gross_payment_volume_run_rate_usdc_axl_usd" },
        ],
      },
      {
        id: "revenue-coverage-ratio",
        title: "Revenue Coverage Ratio",
        description: "Trailing-365-day FIL burned divided by annual PGF deployments plus block reward issuance.",
        y: "revenue_coverage_ratio",
        format: "percent",
        details: [
          {
            title: "Protocol Revenue",
            description: "Total FIL burned over the trailing 365 days, valued at average FIL/USD price.",
            y: "annual_protocol_revenue_usd",
            format: "usd",
          },
          {
            title: "PGF Deployments",
            description: "Public goods funding deployments disbursed over the trailing 365 days.",
            y: "annual_pgf_deployments_usd",
            format: "usd",
          },
          {
            title: "Block Rewards",
            description: "Block reward issuance over the trailing 365 days.",
            y: "annual_block_rewards_usd",
            format: "usd",
          },
        ],
      },
      {
        id: "high-profile-paying-clients",
        title: "High-profile Paying Clients",
        description: "Count of recognized paying clients using Filecoin products.",
        y: "high_profile_paying_clients",
        format: "number",
      },
    ],
  },
  {
    id: "filecoin-onchain-cloud",
    title: "Filecoin Onchain Cloud",
    columns: 2,
    charts: [
      {
        id: "foc-active-payers",
        title: "Active Payers",
        description: "Unique Filecoin Pay payer addresses with at least one active rail at day-end.",
        y: "filecoin_pay_active_payers",
        format: "integer",
      },
      {
        id: "foc-active-rails",
        title: "Active Rails",
        description: "Filecoin Pay rails active at day-end.",
        y: "filecoin_pay_active_rails",
        format: "integer",
      },
      {
        id: "foc-filecoin-pay-paid-usd",
        title: "Filecoin Pay Paid",
        description: "Gross stablecoin paid through Filecoin Pay rails per day, including USDFC and USDC.axl.",
        y: "filecoin_pay_paid_usd",
        format: "usd",
      },
      {
        id: "foc-filecoin-pay-network-fee-arr-usd",
        title: "Network Fee ARR",
        description: "Annualized Filecoin Pay network fee revenue from active eligible recurring stablecoin rails at day-end.",
        y: "filecoin_pay_network_fee_arr_usd",
        format: "usd",
      },
    ],
  },
  {
    id: "power",
    title: "Power",
    columns: 4,
    charts: [
      {
        id: "sector-onboarding",
        title: "Onboarded Data",
        description: "Raw sector data onboarded to the network per day.",
        y: "onboarded_pibs",
        format: "pib",
      },
      {
        id: "sector-termination",
        title: "Terminated Data",
        description: "Raw sector data terminated from the network per day.",
        y: "terminated_pibs",
        format: "pib",
      },
      {
        id: "raw-power",
        title: "Raw Power",
        description: "End-of-day raw storage power committed to the network.",
        y: "raw_power_pibs",
        format: "pib",
      },
      {
        id: "quality-adjusted-power",
        title: "Quality Adjusted Power",
        description: "End-of-day quality-adjusted storage power committed to the network.",
        y: "quality_adjusted_power_pibs",
        format: "pib",
      },
    ],
  },
  {
    id: "activity",
    title: "Activity",
    columns: 3,
    charts: [
      {
        id: "all-transactions",
        title: "Transactions",
        description: "On-chain transactions included per day.",
        y: "transactions",
        format: "number",
        scale: 1_000_000,
        suffix: " M",
      },
      {
        id: "total-value-fil",
        title: "Value Transferred",
        description: "FIL transferred by top-level messages per day.",
        y: "total_value_fil",
        format: "number",
        scale: 1_000_000,
        suffix: " M FIL",
      },
      {
        id: "total-gas-used",
        title: "Gas Used",
        description: "Gas consumed by on-chain messages per day.",
        y: "gas_used_millions",
        format: "number",
        scale: 1_000_000,
        suffix: " T Gas",
      },
    ],
  },
  {
    id: "protocol",
    title: "Protocol",
    columns: 2,
    charts: [
      {
        id: "fil-burned",
        title: "FIL Burned",
        description: "FIL burned per day. Also known as network revenue.",
        y: "protocol_revenue_fil",
        format: "fil",
      },
      {
        id: "protocol-revenue-usd",
        title: "Protocol Revenue",
        description: "FIL burned per day, valued at average FIL/USD price.",
        y: "protocol_revenue_usd",
        format: "usd",
      },
      {
        id: "total-gas-fees",
        title: "Total Gas Fees",
        description: "FIL paid in gas fees per day.",
        y: "total_gas_fee_fil",
        format: "fil",
      },
      {
        id: "base-fee-burn",
        title: "Base Fee Burn",
        description: "FIL burned by message base fees per day.",
        y: "base_fee_burn_fil",
        format: "fil",
      },
      {
        id: "overestimation-burn",
        title: "Overestimation Burn",
        description: "FIL burned by gas overestimation per day.",
        y: "overestimation_burn_fil",
        format: "fil",
      },
      {
        id: "miner-tips",
        title: "Miner Tips",
        description: "FIL paid to miners as message tips per day.",
        y: "miner_tip_fil",
        format: "fil",
      },
      {
        id: "storage-provider-penalties",
        title: "Storage Provider Penalties",
        description: "FIL penalties incurred by storage providers during message execution per day.",
        y: "message_storage_provider_penalty_fil",
        format: "fil",
      },
      {
        id: "locked-fil",
        title: "Locked FIL",
        description: "End-of-day FIL locked in the network.",
        y: "locked_fil",
        format: "mfil",
      },
      {
        id: "pledge-collateral",
        title: "Pledge Collateral",
        description: "End-of-day FIL locked as storage provider pledge collateral.",
        y: "pledge_collateral_fil",
        format: "mfil",
      },
      {
        id: "circulating-fil",
        title: "Circulating FIL",
        description: "End-of-day FIL circulating and tradeable in the economy.",
        y: "circulating_fil",
        format: "mfil",
      },
      {
        id: "yearly-inflation-rate",
        title: "Yearly Inflation Rate",
        description: "Year-over-year change in circulating FIL.",
        y: "yearly_inflation_rate",
        format: "percent",
      },
      {
        id: "locked-to-circulating-ratio",
        title: "Locked to Circulating Ratio",
        description: "Percentage of circulating FIL that is locked.",
        y: "locked_to_circulating_ratio",
        format: "percent",
      },
      {
        id: "block-rewards-fil",
        title: "Block Rewards",
        description: "FIL block rewards minted by the network per day.",
        y: "block_rewards_fil",
        format: "fil",
      },
      {
        id: "block-rewards-usd",
        title: "Block Rewards Value",
        description: "Block rewards minted per day, valued at average FIL/USD price.",
        y: "block_rewards_usd",
        format: "usd",
      },
      {
        id: "mining-yield",
        title: "Mining Yield",
        description: "Annualized block rewards relative to locked FIL.",
        y: "mining_yield",
        format: "percent",
      },
      {
        id: "reward-per-wincount",
        title: "Reward per Wincount",
        description: "Average FIL reward allocated per winning proof per day.",
        y: "reward_per_wincount_fil",
        format: "fil",
      },
    ],
  },
  {
    id: "markets",
    title: "Markets",
    columns: 3,
    charts: [
      {
        id: "fil-token-price",
        title: "FIL Token Price",
        description: "Average daily FIL token price in USD.",
        y: "fil_token_price_avg_usd",
        format: "usd",
      },
      {
        id: "fil-token-volume",
        title: "FIL Trading Volume",
        description: "Reported daily FIL trading volume in USD.",
        y: "fil_token_volume_usd",
        format: "usd",
        scale: 1_000_000,
        suffix: "M",
      },
      {
        id: "fil-token-market-cap",
        title: "FIL Market Cap",
        description: "Daily FIL market capitalization in USD.",
        y: "fil_token_market_cap_usd",
        format: "usd",
        scale: 1_000_000_000,
        suffix: "B",
      },
    ],
  },
]

const datasetColumnNames = [
  "date",
  ...new Set(
    sections.flatMap((section) =>
      section.charts.flatMap((chart) => [
        chart.y,
        ...(chart.series?.map((series) => series.y) ?? []),
        ...(chart.details?.map((detailChart) => detailChart.y) ?? []),
      ]),
    ),
  ),
]
const serializedDailyMetrics = JSON.stringify(
  Object.fromEntries(
    datasetColumnNames.map((key) => [key, dailyMetrics.map((row) => row[key] ?? null)]),
  ),
)
---

<Layout
  title="Filecoin in Numbers | Filecoin Data Portal"
  description="Core Filecoin metrics with interactive charts for KPIs, sectors, power, activity, state market deals, and economics."
>
  <div class="numbers-toolbar">
    <h1>Filecoin in Numbers</h1>
    <nav class="numbers-toc" aria-label="Numbers sections">
      {sections.map((section) => <a href={`#${section.id}`}>{section.title}</a>)}
    </nav>
    <div class="numbers-toolbar__controls">
      <div class="chart-range-toggle" role="group" aria-label="Chart timeframe">
        <button type="button" data-chart-range="6m" aria-pressed="false">6M</button>
        <button type="button" data-chart-range="1y" aria-pressed="true">1Y</button>
        <button type="button" data-chart-range="all" aria-pressed="false">All</button>
      </div>
      <button type="button" class="numbers-expand-toggle" data-expand-all aria-pressed="false">Expand Charts</button>
    </div>
  </div>

  {
    sections.map((section) => (
      <section class="numbers-section" aria-labelledby={section.id}>
        <SectionHeading id={section.id} label={section.title} class="numbers-section__legend" />

        <div class={`stat-grid stat-grid--${section.columns}`}>
          {section.charts.map((chart) => <StatCard {...chart} />)}
        </div>
      </section>
    ))
  }

  <script
    type="application/json"
    is:inline
    data-numbers-dataset
    set:html={serializedDailyMetrics}
  ></script>

  <script src="../scripts/numbers.ts"></script>
</Layout>
