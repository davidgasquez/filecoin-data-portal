      },
      {
        id: "locked-fil",
        title: "Locked FIL",
        y: "locked_fil",
        format: "number",
        formatScale: 1_000_000,
        formatSuffix: " M FIL",
      },
      {
        id: "storage-providers-collateral",
        title: "Storage Providers Collateral",
        y: "storage_providers_collateral",
        format: "fil",
      },
      {
        id: "burnt-fil",
        title: "Burnt FIL",
        y: "burnt_fil",
        format: "number",
        formatScale: 1_000_000,
        formatSuffix: " M FIL",
      },
      {
        id: "miner-tip-fil",
