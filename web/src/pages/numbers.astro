---
import type { ComponentProps } from "astro/types"
import dailyMetricsDataset from "../data/generated/filecoin-daily-metrics.json"
import SectionHeading from "../components/SectionHeading.astro"
import StatCard from "../components/StatCard.astro"
import Layout from "../layouts/Layout.astro"

type StatCardProps = ComponentProps<typeof StatCard>
type DatasetRowValue = string | number | null
type DatasetRow = Record<string, DatasetRowValue>
type DatasetColumn = DatasetRowValue[]
type ColumnarDataset = Record<string, DatasetColumn>

type LineChartSeriesConfig = {
  label: string
  y: string
}

type NumbersChartConfig = Pick<
  StatCardProps,
  | "id"
  | "title"
  | "description"
  | "y"
  | "format"
  | "formatScale"
  | "formatPrefix"
  | "formatSuffix"
  | "percentMode"
> & {
  series?: LineChartSeriesConfig[]
  details?: {
    charts: NumbersDetailChartConfig[]
  }
}

type NumbersDetailChartConfig = Pick<
  StatCardProps,
  | "id"
  | "title"
  | "description"
  | "y"
  | "format"
  | "formatScale"
  | "formatPrefix"
  | "formatSuffix"
  | "percentMode"
>

type NumbersSectionConfig = {
  id: string
  title: string
  columns?: 2 | 3 | 4
  charts: NumbersChartConfig[]
}

const dailyMetrics = dailyMetricsDataset as DatasetRow[]
const filecoinPayArrSeries: LineChartSeriesConfig[] = [
  { label: "USDFC", y: "arr_filecoin_pay_usdfc_usd" },
  { label: "USDC.axl", y: "arr_filecoin_pay_usdc_axl_usd" },
]

if (dailyMetrics.length === 0) {
  throw new Error("Generated daily metrics dataset is empty")
}

const sections = [
  {
    id: "key-metrics",
    title: "Ecosystem KPIs",
    columns: 3,
    charts: [
      {
        id: "total-arr-filecoin-pay-usd",
        title: "Filecoin Pay ARR Run-Rate",
        description: "Annualized USD value of active recurring Filecoin Pay stablecoin rails, including USDFC and USDC.axl, at each UTC day-end.",
        y: "arr_filecoin_pay_usd",
        format: "usd",
        series: filecoinPayArrSeries,
      },
      {
        id: "revenue-coverage-ratio",
        title: "Revenue Coverage Ratio",
        description: "Trailing-365-day protocol revenue divided by annual PGF deployments plus block reward issuance.",
        y: "revenue_coverage_ratio",
        format: "percent",
        details: {
          charts: [
            {
              id: "annual-protocol-revenue-usd",
              title: "Protocol Revenue",
              description: "Sum of FIL burned times average FIL/USD price, trailing 365 days.",
              y: "annual_protocol_revenue_usd",
              format: "usd",
            },
            {
              id: "annual-pgf-deployments-usd",
              title: "PGF Deployments",
              description: "Public goods funding deployments disbursed over the trailing 365 days.",
              y: "annual_pgf_deployments_usd",
              format: "usd",
            },
            {
              id: "annual-block-rewards-usd",
              title: "Block Rewards",
              description: "Block reward issuance over the trailing 365 days.",
              y: "annual_block_rewards_usd",
              format: "usd",
            },
          ],
        },
      },
      {
        id: "high-profile-paying-clients",
        title: "High Profile Paying Clients",
        description: "Count of recognized paying clients using Filecoin products.",
        y: "high_profile_paying_clients",
        format: "number",
      },
    ],
  },
  {
    id: "filecoin-onchain-cloud",
    title: "Filecoin Onchain Cloud",
    columns: 2,
    charts: [
      {
        id: "foc-active-payers",
        title: "Active Payers",
        description: "Unique Filecoin Pay payer addresses with at least one active rail at each UTC day-end.",
        y: "filecoin_pay_active_payers",
        format: "integer",
      },
      {
        id: "foc-active-rails",
        title: "Active Rails",
        description: "Filecoin Pay rails active at each UTC day-end.",
        y: "filecoin_pay_active_rails",
        format: "integer",
      },
      {
        id: "foc-filecoin-pay-paid-usd",
        title: "Filecoin Pay Paid",
        description: "Gross stablecoin paid through Filecoin Pay rails per day, including USDFC and USDC.axl.",
        y: "filecoin_pay_paid_usd",
        format: "usd",
      },
      {
        id: "foc-arr-filecoin-pay-usd",
        title: "Filecoin Pay ARR Run-Rate",
        description: "Annualized USD value of active recurring Filecoin Pay stablecoin rails, including USDFC and USDC.axl, at each UTC day-end.",
        y: "arr_filecoin_pay_usd",
        format: "usd",
        series: filecoinPayArrSeries,
      },
    ],
  },
  {
    id: "power",
    title: "Power",
    columns: 4,
    charts: [
      {
        id: "sector-onboarding",
        title: "Onboarded PiBs",
        description: "Raw sector data onboarded to the network per day.",
        y: "onboarded_pibs",
        format: "pib",
      },
      {
        id: "sector-termination",
        title: "Terminated PiBs",
        description: "Raw sector data terminated from the network per day.",
        y: "terminated_pibs",
        format: "pib",
      },
      {
        id: "raw-power",
        title: "Raw Power",
        description: "End-of-day raw storage power committed to the network.",
        y: "raw_power_pibs",
        format: "pib",
      },
      {
        id: "quality-adjusted-power",
        title: "Quality Adjusted Power",
        description: "End-of-day quality-adjusted storage power committed to the network.",
        y: "quality_adjusted_power_pibs",
        format: "pib",
      },
    ],
  },
  {
    id: "activity",
    title: "Activity",
    columns: 3,
    charts: [
      {
        id: "all-transactions",
        title: "All Transactions",
        description: "On-chain transactions included per day.",
        y: "transactions",
        format: "number",
        formatScale: 1_000_000,
        formatSuffix: " M",
      },
      {
        id: "total-value-fil",
        title: "Total Value FIL",
        description: "FIL transferred by top-level messages per day.",
        y: "total_value_fil",
        format: "number",
        formatScale: 1_000_000,
        formatSuffix: " M FIL",
      },
      {
        id: "total-gas-used",
        title: "Total Gas Used",
        description: "Total gas consumed by on-chain messages per day.",
        y: "gas_used_millions",
        format: "number",
        formatScale: 1_000_000,
        formatSuffix: " T Gas",
      },
    ],
  },
  {
    id: "protocol",
    title: "Protocol",
    columns: 2,
    charts: [
      {
        id: "burnt-fil",
        title: "Burnt FIL",
        description: "Amount of FIL burned as part of on-chain computations and penalties.",
        y: "protocol_revenue_fil",
        format: "fil",
      },
      {
        id: "block-rewards-fil",
        title: "Block Rewards FIL",
        description: "FIL block rewards minted by the network per day.",
        y: "block_rewards_fil",
        format: "fil",
      },
      {
        id: "mining-yield",
        title: "Mining Yield",
        description: "Annualized block rewards relative to locked FIL.",
        y: "mining_yield",
        format: "percent",
      },
      {
        id: "reward-per-wincount",
        title: "Reward Per Wincount",
        description: "Average FIL reward allocated per winning proof each day.",
        y: "reward_per_wincount_fil",
        format: "fil",
      },
      {
        id: "circulating-fil",
        title: "Circulating FIL",
        description: "Amount of FIL circulating and tradeable in the economy.",
        y: "circulating_fil",
        format: "mfil",
      },
      {
        id: "locked-to-circulating-ratio",
        title: "Locked to Circulating Ratio",
        description: "Percentage of circulating FIL that is locked.",
        y: "locked_to_circulating_ratio",
        format: "percent",
      },
    ],
  },
  {
    id: "markets",
    title: "Markets",
    columns: 3,
    charts: [
      {
        id: "fil-token-price",
        title: "FIL Token Price",
        description: "Average daily FIL token price in USD.",
        y: "fil_token_price_avg_usd",
        format: "usd",
      },
      {
        id: "fil-token-volume",
        title: "FIL Token Volume",
        description: "Reported daily FIL trading volume in USD.",
        y: "fil_token_volume_usd",
        format: "usd",
        formatScale: 1_000_000,
        formatSuffix: "M",
      },
      {
        id: "fil-token-market-cap",
        title: "FIL Token Market Cap",
        description: "Daily FIL market capitalization in USD.",
        y: "fil_token_market_cap_usd",
        format: "usd",
        formatScale: 1_000_000_000,
        formatSuffix: "B",
      },
    ],
  },
] as NumbersSectionConfig[]

const chartX = "date"
const datasetColumnNames = [
  chartX,
  ...new Set(
    sections.flatMap((section) =>
      section.charts.flatMap((chart) => [
        chart.y,
        ...(chart.series?.map((series) => series.y) ?? []),
        ...(chart.details?.charts.map((detailChart) => detailChart.y) ?? []),
      ]),
    ),
  ),
]
const serializedDailyMetrics = JSON.stringify(
  Object.fromEntries(
    datasetColumnNames.map((key) => [key, dailyMetrics.map((row) => row[key] ?? null)]),
  ) satisfies ColumnarDataset,
)
---

<Layout
  title="Filecoin in Numbers | Filecoin Data Portal"
  description="Core Filecoin metrics with interactive charts for KPIs, sectors, power, activity, state market deals, and economics."
>
  <div class="numbers-toolbar">
    <h1>Filecoin in Numbers</h1>
    <div class="chart-range-toggle" role="group" aria-label="Chart timeframe">
      <button type="button" data-line-chart-range="6m" aria-pressed="false">6M</button>
      <button type="button" data-line-chart-range="1y" aria-pressed="true">1Y</button>
      <button type="button" data-line-chart-range="all" aria-pressed="false">All</button>
    </div>
  </div>

  {
    sections.map((section) => (
      <section class="numbers-section" aria-labelledby={section.id}>
        <SectionHeading id={section.id} label={section.title} class="numbers-section__legend" />

        <div class={`stat-grid${section.columns ? ` stat-grid--${section.columns}` : ""}`}>
          {section.charts.map((chart) => (
            <StatCard
              id={chart.id}
              title={chart.title}
              description={chart.description}
              x={chartX}
              y={chart.y}
              format={chart.format}
              formatScale={chart.formatScale}
              formatPrefix={chart.formatPrefix}
              formatSuffix={chart.formatSuffix}
              percentMode={chart.percentMode}
              series={chart.series}
            >
              {chart.details && (
                <div class="stat-card__details" slot="details">
                  <div class="stat-card__detail-grid">
                    {chart.details.charts.map((detailChart) => (
                      <div
                        class="stat-card__detail"
                        data-component-spark
                        data-chart-id={detailChart.id}
                        data-x={chartX}
                        data-y={detailChart.y}
                        data-format={detailChart.format}
                        data-format-scale={detailChart.formatScale !== undefined ? detailChart.formatScale : undefined}
                        data-format-prefix={detailChart.formatPrefix ?? undefined}
                        data-format-suffix={detailChart.formatSuffix ?? undefined}
                        data-percent-mode={detailChart.percentMode ?? "fraction"}
                      >
                        <div class="stat-card__detail-header">
                          <span>{detailChart.title}</span>
                          <strong data-component-spark-value></strong>
                        </div>
                        {detailChart.description && <p>{detailChart.description}</p>}
                        <div class="stat-card__detail-chart">
                          <svg class="stat-card__detail-spark" aria-hidden="true"></svg>
                          <div class="line-chart__tooltip" data-component-spark-tooltip hidden></div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </StatCard>
          ))}
        </div>
      </section>
    ))
  }

  <script
    type="application/json"
    is:inline
    data-numbers-dataset
    set:html={serializedDailyMetrics}
  ></script>

  <script>
    type DatasetRowValue = string | number | null
    type DatasetColumn = DatasetRowValue[]
    type ColumnarDataset = Record<string, DatasetColumn>

    type LineChartPoint = {
      timestamp: number
      value: number
    }

    type LineChartSeriesConfig = {
      label: string
      y: string
    }

    type ParsedLineChartSeries = LineChartSeriesConfig & {
      data: LineChartPoint[]
    }

    type LineChartFormat =
      | "integer"
      | "number"
      | "pib"
      | "tib"
      | "fil"
      | "mfil"
      | "usd"
      | "percent"

    type PercentMode = "fraction" | "points"

    type RangeType = "6m" | "1y" | "all"

    type ParsedChart = {
      id: string
      node: HTMLElement
      toggleButton: HTMLAnchorElement
      title: string
      data: LineChartPoint[]
      series: ParsedLineChartSeries[]
      format: LineChartFormat
      formatScale: number
      formatPrefix: string
      formatSuffix: string
      percentMode: PercentMode
      showMovingAverage: boolean
      movingAverageWindowDays: number
    }

    const DATASET_SELECTOR = "[data-numbers-dataset]"
    const CHART_SELECTOR = "[data-line-chart]"
    const STAT_CARD_SELECTOR = "[data-stat-card]"
    const COMPONENT_SPARK_SELECTOR = "[data-component-spark]"
    const RANGE_BUTTON_SELECTOR = "[data-line-chart-range]"
    const RANGE_PARAM = "range"
    const CHART_MARGIN = { top: 32, right: 10, bottom: 28, left: 10 }
    const DAY_IN_MS = 86_400_000

    const chartNodes = Array.from(document.querySelectorAll<HTMLElement>(CHART_SELECTOR))

    if (chartNodes.length > 0) {
      const dataset = parseDataset()
      const charts = chartNodes.map((node) => parseChart(node, dataset))
      let currentRange = getInitialRangeFromUrl()
      let expandedChartId = getExpandedChartFromUrl()

      const tooltipDateFormatter = new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
        timeZone: "UTC",
      })

      function parseDataset(): ColumnarDataset {
        const datasetScript = document.querySelector<HTMLScriptElement>(DATASET_SELECTOR)

        if (!datasetScript?.textContent) {
          throw new Error("Numbers dataset is missing")
        }

        const rawDataset = JSON.parse(datasetScript.textContent) as unknown

        if (
          rawDataset === null ||
          typeof rawDataset !== "object" ||
          Array.isArray(rawDataset)
        ) {
          throw new Error("Numbers dataset must be a columnar object")
        }

        const dataset = rawDataset as Record<string, unknown>

        for (const [key, value] of Object.entries(dataset)) {
          if (!Array.isArray(value)) {
            throw new Error(`Numbers dataset column ${key} must be an array`)
          }
        }

        return dataset as ColumnarDataset
      }

      function parseChart(node: HTMLElement, dataset: ColumnarDataset): ParsedChart {
        const chartId = node.dataset.chartId
        const x = node.dataset.x
        const y = node.dataset.y
        const toggleButton = node.querySelector<HTMLAnchorElement>("[data-line-chart-toggle]")
        const titleNode = node.querySelector<HTMLElement>(".line-chart__title")

        if (!chartId || !x || !y) {
          throw new Error("Line chart is missing required dataset attributes")
        }

        if (!toggleButton || !titleNode?.textContent?.trim()) {
          throw new Error(`Line chart ${chartId} markup is incomplete`)
        }

        const xColumn = dataset[x]
        const yColumn = dataset[y]

        if (!xColumn || !yColumn) {
          throw new Error(`Line chart ${chartId} references missing dataset columns`)
        }

        const series = parseSeriesConfig(chartId, node.dataset.series).map((config) => {
          const seriesColumn = dataset[config.y]

          if (!seriesColumn) {
            throw new Error(`Line chart ${chartId} references missing series column ${config.y}`)
          }

          return {
            ...config,
            data: parsePointColumn(chartId, xColumn, seriesColumn, config.y),
          }
        })

        return {
          id: chartId,
          node,
          toggleButton,
          title: titleNode.textContent.trim(),
          data: parsePointColumn(chartId, xColumn, yColumn, y),
          series,
          format: parseFormat(node.dataset.format),
          formatScale: parsePositiveNumber(node.dataset.formatScale, 1),
          formatPrefix: node.dataset.formatPrefix ?? "",
          formatSuffix: node.dataset.formatSuffix ?? "",
          percentMode: parsePercentMode(node.dataset.percentMode),
          showMovingAverage: node.dataset.showMovingAverage === "true",
          movingAverageWindowDays: parsePositiveInteger(
            node.dataset.movingAverageWindowDays,
            30,
          ),
        }
      }

      function parsePointColumn(
        chartId: string,
        xColumn: DatasetColumn,
        yColumn: DatasetColumn,
        y: string,
      ): LineChartPoint[] {
        if (xColumn.length !== yColumn.length) {
          throw new Error(`Line chart ${chartId} dataset columns must be the same length`)
        }

        return xColumn
          .map((rawTimestamp, rowIndex) =>
            toPoint(chartId, rawTimestamp, yColumn[rowIndex], y, rowIndex),
          )
          .filter((point): point is LineChartPoint => point !== null)
          .sort((left, right) => left.timestamp - right.timestamp)
      }

      function parseSeriesConfig(chartId: string, rawSeries: string | undefined): LineChartSeriesConfig[] {
        if (!rawSeries) {
          return []
        }

        const parsed = JSON.parse(rawSeries) as unknown

        if (!Array.isArray(parsed)) {
          throw new Error(`Line chart ${chartId} series config must be an array`)
        }

        return parsed.map((item, index) => {
          if (item === null || typeof item !== "object" || Array.isArray(item)) {
            throw new Error(`Line chart ${chartId} series ${index} must be an object`)
          }

          const { label, y } = item as Record<string, unknown>

          if (typeof label !== "string" || label.trim() === "") {
            throw new Error(`Line chart ${chartId} series ${index} must have a label`)
          }

          if (typeof y !== "string" || y.trim() === "") {
            throw new Error(`Line chart ${chartId} series ${index} must have a y column`)
          }

          return { label: label.trim(), y: y.trim() }
        })
      }

      function toPoint(
        chartId: string,
        rawTimestamp: DatasetRowValue,
        rawValue: DatasetRowValue,
        y: string,
        rowIndex: number,
      ): LineChartPoint | null {
        if (rawTimestamp == null || rawValue == null) {
          return null
        }

        const timestamp = toTimestamp(chartId, rawTimestamp)
        const value = Number(rawValue)

        if (!Number.isFinite(value)) {
          throw new Error(`Line chart ${chartId} row ${rowIndex} has an invalid y value for ${y}`)
        }

        return { timestamp, value }
      }

      function toTimestamp(chartId: string, value: DatasetRowValue): number {
        if (typeof value === "number" && Number.isFinite(value)) {
          return value
        }

        if (typeof value === "string") {
          const timestamp = new Date(value).getTime()

          if (Number.isFinite(timestamp)) {
            return timestamp
          }
        }

        throw new Error(`Line chart ${chartId} has an invalid x value: ${String(value)}`)
      }

      function parseFormat(value: string | undefined): LineChartFormat {
        switch (value) {
          case "integer":
          case "number":
          case "pib":
          case "tib":
          case "fil":
          case "mfil":
          case "usd":
          case "percent":
            return value
          case undefined:
            return "number"
          default:
            throw new Error(`Unsupported line chart format: ${value}`)
        }
      }

      function parsePositiveInteger(value: string | undefined, fallback: number): number {
        const parsed = Number(value)

        if (!Number.isInteger(parsed) || parsed <= 0) {
          return fallback
        }

        return parsed
      }

      function parsePositiveNumber(value: string | undefined, fallback: number): number {
        const parsed = Number(value)

        if (!Number.isFinite(parsed) || parsed <= 0) {
          return fallback
        }

        return parsed
      }

      function parsePercentMode(value: string | undefined): PercentMode {
        if (value === "points") {
          return value
        }

        return "fraction"
      }

      function parseRange(value: string | null): RangeType | null {
        if (value === "6m" || value === "1y" || value === "all") {
          return value
        }

        return null
      }

      function getDefaultRange(): RangeType {
        const activeButton = document.querySelector<HTMLButtonElement>(
          `${RANGE_BUTTON_SELECTOR}[aria-pressed="true"]`,
        )

        return parseRange(activeButton?.dataset.lineChartRange ?? null) ?? "1y"
      }

      function getInitialRangeFromUrl(): RangeType {
        const range = parseRange(new URL(window.location.href).searchParams.get(RANGE_PARAM))

        return range ?? getDefaultRange()
      }

      function formatDecimal(value: number, maximumFractionDigits: number): string {
        return value.toLocaleString("en-US", {
          maximumFractionDigits,
        })
      }

      function formatUsd(value: number, maximumFractionDigits: number): string {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          maximumFractionDigits,
        }).format(value)
      }

      function scaleDisplayValue(value: number, scale: number): number {
        return value / scale
      }

      function formatValue(
        value: number,
        chart: Pick<ParsedChart, "format" | "formatScale" | "formatPrefix" | "formatSuffix" | "percentMode">,
        context: "headline" | "tick" | "tooltip",
      ): string {
        const maximumFractionDigits = context === "tick" ? 1 : 2
        const scaledValue = scaleDisplayValue(value, chart.formatScale)

        if (chart.format === "integer") {
          return `${chart.formatPrefix}${Math.round(scaledValue).toLocaleString("en-US")}${chart.formatSuffix}`
        }

        if (chart.format === "mfil") {
          const millionsValue = scaledValue / 1_000_000
          const suffix = context === "tick" ? `M${chart.formatSuffix}` : ` M FIL${chart.formatSuffix}`
          return `${chart.formatPrefix}${formatDecimal(millionsValue, context === "tick" ? 1 : 2)}${suffix}`
        }

        if (chart.format === "usd") {
          return `${chart.formatPrefix}${formatUsd(scaledValue, context === "tick" ? 0 : 2)}${chart.formatSuffix}`
        }

        if (chart.format === "percent") {
          const percentValue = chart.percentMode === "fraction" ? scaledValue * 100 : scaledValue
          const percentFractionDigits = context === "tick" ? 0 : 2
          return `${chart.formatPrefix}${formatDecimal(percentValue, percentFractionDigits)}%${chart.formatSuffix}`
        }

        const suffixByFormat = {
          number: "",
          pib: " PiB",
          tib: " TiB",
          fil: " FIL",
        } satisfies Record<Exclude<LineChartFormat, "integer" | "mfil" | "usd" | "percent">, string>

        return `${chart.formatPrefix}${formatDecimal(scaledValue, maximumFractionDigits)}${suffixByFormat[chart.format]}${chart.formatSuffix}`
      }

      function formatPercentChange(currentValue: number, previousValue: number): string {
        if (previousValue === 0) {
          return currentValue === 0 ? "0.00%" : "N/A"
        }

        const percentChange = ((currentValue - previousValue) / previousValue) * 100
        const sign = percentChange > 0 ? "+" : ""

        return `${sign}${formatDecimal(percentChange, 2)}%`
      }

      function getPointsForRange(points: LineChartPoint[], range: RangeType): LineChartPoint[] {
        if (range === "all") {
          return points
        }

        const latestTimestamp = points[points.length - 1]?.timestamp

        if (latestTimestamp == null) {
          return []
        }

        const latestDate = new Date(latestTimestamp)
        const monthsBack = range === "6m" ? 6 : 12
        const cutoff = new Date(
          Date.UTC(
            latestDate.getUTCFullYear(),
            latestDate.getUTCMonth() - monthsBack,
            latestDate.getUTCDate(),
          ),
        ).getTime()

        return points.filter((point) => point.timestamp >= cutoff)
      }

      function findClosestPointIndex(points: { x: number }[], x: number): number {
        if (points.length === 1) {
          return 0
        }

        let left = 0
        let right = points.length - 1

        while (left < right) {
          const mid = Math.floor((left + right) / 2)

          if (points[mid].x < x) {
            left = mid + 1
          } else {
            right = mid
          }
        }

        const rightCandidate = left
        const leftCandidate = Math.max(0, rightCandidate - 1)

        return Math.abs(points[rightCandidate].x - x) <
          Math.abs(points[leftCandidate].x - x)
          ? rightCandidate
          : leftCandidate
      }

      function buildMovingAverage(values: number[], windowSize: number): number[] {
        if (windowSize < 1) {
          throw new Error("Moving average window size must be greater than zero")
        }

        let runningTotal = 0

        return values.map((value, index) => {
          runningTotal += value

          if (index >= windowSize) {
            runningTotal -= values[index - windowSize]
          }

          const sampleSize = Math.min(windowSize, index + 1)
          return runningTotal / sampleSize
        })
      }

      function buildTicks(min: number, max: number, count: number): number[] {
        if (count < 2) {
          return [min]
        }

        const step = (max - min) / (count - 1)
        return Array.from({ length: count }, (_, index) => min + index * step)
      }

      function updateRangeButtons(range: RangeType): void {
        const buttons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

        for (const button of buttons) {
          const isActive = button.dataset.lineChartRange === range
          button.setAttribute("aria-pressed", String(isActive))
        }
      }

      function getChartHeight(chartNode: HTMLElement): number {
        const value = Number.parseFloat(
          getComputedStyle(chartNode).getPropertyValue("--line-chart-height"),
        )

        if (!Number.isFinite(value) || value <= 0) {
          return 240
        }

        return value
      }

      function getChartById(chartId: string | null): ParsedChart | undefined {
        if (chartId === null) {
          return undefined
        }

        return charts.find((chart) => chart.id === chartId)
      }

      function getExpandedChartFromUrl(): string | null {
        const hash = window.location.hash.slice(1)

        return getChartById(hash)?.id ?? null
      }

      function updateUrlState(): void {
        const url = new URL(window.location.href)

        if (currentRange === "1y") {
          url.searchParams.delete(RANGE_PARAM)
        } else {
          url.searchParams.set(RANGE_PARAM, currentRange)
        }

        url.hash = expandedChartId ? `#${expandedChartId}` : ""

        history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`)
      }

      function scrollChartIntoView(chartId: string | null, behavior: ScrollBehavior = "smooth"): void {
        const chart = getChartById(chartId)
        const toolbar = document.querySelector<HTMLElement>(".numbers-toolbar")

        if (!chart) {
          return
        }

        const toolbarOffset = toolbar ? toolbar.getBoundingClientRect().height + 16 : 16
        const chartTop = window.scrollY + chart.node.getBoundingClientRect().top

        window.scrollTo({
          top: Math.max(0, chartTop - toolbarOffset),
          behavior,
        })
      }

      function syncExpandedChartState(): void {
        for (const chart of charts) {
          const isExpanded = chart.id === expandedChartId
          chart.node.classList.toggle("is-expanded", isExpanded)
          chart.toggleButton.setAttribute("aria-expanded", String(isExpanded))
          chart.toggleButton.setAttribute(
            "aria-label",
            `${isExpanded ? "Close" : "Expand"} ${chart.title}`,
          )
          chart.toggleButton.title = `${isExpanded ? "Close" : "Expand"} ${chart.title}`
          chart.toggleButton.textContent = isExpanded ? "-" : "+"
        }
      }

      function setExpandedChart(
        nextChartId: string | null,
        options: { scrollIntoView?: boolean } = {},
      ): void {
        if (expandedChartId === nextChartId) {
          return
        }

        const previousExpandedChartId = expandedChartId
        expandedChartId = nextChartId
        updateUrlState()
        syncExpandedChartState()
        renderAllCharts()

        if (options.scrollIntoView && nextChartId) {
          requestAnimationFrame(() => {
            scrollChartIntoView(nextChartId)
          })
        }

        if (nextChartId) {
          getChartById(nextChartId)?.toggleButton.focus()
          return
        }

        if (previousExpandedChartId) {
          getChartById(previousExpandedChartId)?.toggleButton.focus()
          requestAnimationFrame(() => {
            scrollChartIntoView(previousExpandedChartId, "instant")
          })
        }
      }

      function setupHeadlineTip(
        chartNode: HTMLElement,
        trigger: HTMLElement,
        text: string,
      ): void {
        const tip = chartNode.querySelector<HTMLElement>("[data-line-chart-headline-tip]")

        if (!tip) {
          return
        }

        if (!text) {
          tip.hidden = true
          trigger.removeAttribute("data-has-tip")
          return
        }

        tip.innerHTML = text
        trigger.setAttribute("data-has-tip", "")

        trigger.onmouseenter = () => {
          tip.hidden = false
        }

        trigger.onmouseleave = () => {
          tip.hidden = true
        }
      }

      function renderChart(chart: ParsedChart): void {
        const filteredData = getPointsForRange(chart.data, currentRange)
        const filteredSeries = chart.series
          .map((series) => ({ ...series, data: getPointsForRange(series.data, currentRange) }))
          .filter((series) => series.data.length >= 2)
        const hasVisibleSeries = filteredSeries.length > 0
        const renderedData = hasVisibleSeries
          ? filteredSeries.flatMap((series) => series.data)
          : filteredData

        const svg = chart.node.querySelector<SVGElement>(".line-chart__svg")
        const tooltip = chart.node.querySelector<HTMLDivElement>(".line-chart__tooltip")
        const emptyMessage = chart.node.querySelector<HTMLParagraphElement>(".line-chart__empty")
        const headlineValue = chart.node.querySelector<HTMLSpanElement>("[data-line-chart-last-value]")

        if (!svg || !tooltip || !emptyMessage || !headlineValue) {
          throw new Error(`Line chart ${chart.id} markup is incomplete`)
        }

        const width = Math.max(320, chart.node.clientWidth)
        const height = getChartHeight(chart.node)
        const margin = CHART_MARGIN
        const plotWidth = width - margin.left - margin.right
        const plotHeight = height - margin.top - margin.bottom

        if (filteredData.length < 2 || renderedData.length < 2) {
          svg.innerHTML = ""
          emptyMessage.hidden = false
          tooltip.hidden = true
          tooltip.textContent = ""
          headlineValue.hidden = true
          headlineValue.textContent = ""
          return
        }

        emptyMessage.hidden = true

        const minX = Math.min(...renderedData.map((point) => point.timestamp))
        const maxX = Math.max(...renderedData.map((point) => point.timestamp))
        const rawValues = filteredData.map((point) => point.value)
        const domainValues = renderedData.map((point) => point.value)
        const displayValues = chart.showMovingAverage
          ? buildMovingAverage(rawValues, chart.movingAverageWindowDays)
          : rawValues

        const dataMinY = Math.min(...domainValues)
        const dataMaxY = Math.max(...domainValues)
        const startsAtZero = dataMinY >= 0
        const minY = startsAtZero ? 0 : dataMinY
        let maxY = dataMaxY

        if (maxY === minY) {
          maxY = minY + 1
        }

        maxY += (maxY - minY) * 0.08

        const scaleX = (value: number): number =>
          margin.left + ((value - minX) / Math.max(maxX - minX, DAY_IN_MS)) * plotWidth

        const scaleY = (value: number): number =>
          margin.top + ((maxY - value) / (maxY - minY)) * plotHeight

        const rawPoints = filteredData.map((point) => ({
          ...point,
          x: scaleX(point.timestamp),
          y: scaleY(point.value),
        }))

        const points = filteredData.map((point, index) => ({
          timestamp: point.timestamp,
          rawValue: point.value,
          value: displayValues[index],
          x: scaleX(point.timestamp),
          y: scaleY(displayValues[index]),
        }))

        const scaledSeries = filteredSeries.map((series, seriesIndex) => ({
          ...series,
          seriesIndex,
          points: series.data.map((point) => ({
            ...point,
            x: scaleX(point.timestamp),
            y: scaleY(point.value),
          })),
        }))

        const latestPoint = points[points.length - 1]

        if (chart.showMovingAverage) {
          const compareIndex = Math.max(0, points.length - 1 - chart.movingAverageWindowDays)
          const prevValue = points[compareIndex].value
          const trend = latestPoint.value > prevValue ? "▲" : latestPoint.value < prevValue ? "▼" : "■"
          const now = formatValue(latestPoint.value, chart, "tooltip")
          const ago = formatValue(prevValue, chart, "tooltip")
          const monthOverMonthChange = formatPercentChange(latestPoint.value, prevValue)

          headlineValue.textContent = `${formatValue(latestPoint.value, chart, "headline")} ${trend}`
          setupHeadlineTip(
            chart.node,
            headlineValue,
            `<span class="tip-row"><span>Now</span><span class="tip-dots"></span><span>${now}</span></span>` +
            `<span class="tip-row"><span>30 Days Ago</span><span class="tip-dots"></span><span>${ago}</span></span>` +
            `<span class="tip-row"><span>MoM % Change</span><span class="tip-dots"></span><span>${monthOverMonthChange}</span></span>`,
          )
        } else {
          headlineValue.textContent = formatValue(latestPoint.value, chart, "headline")
          setupHeadlineTip(chart.node, headlineValue, "")
        }

        headlineValue.hidden = false

        const rawPath = rawPoints
          .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
          .join(" ")

        const displayPath = points
          .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
          .join(" ")

        const rangeDays = Math.round((maxX - minX) / DAY_IN_MS)
        const xTickDateFormatter = new Intl.DateTimeFormat("en-US", {
          month: "short",
          ...(rangeDays > 500 ? { year: "2-digit" } : { day: "numeric", year: "2-digit" }),
          timeZone: "UTC",
        })

        const yTicks = buildTicks(minY, maxY, 4)
        const xTicks = buildTicks(minX, maxX, 4)

        const yTickMarkup = yTicks
          .map((tick) => {
            const y = scaleY(tick)

            return `
              <line x1="${margin.left}" y1="${y}" x2="${width - margin.right}" y2="${y}" class="line-chart__gridline" />
              <text x="${margin.left + 4}" y="${y - 4}" text-anchor="start" class="line-chart__label">${formatValue(tick, chart, "tick")}</text>
            `
          })
          .join("")

        const xTickMarkup = xTicks
          .map((tick, index) => {
            const x = scaleX(tick)
            const anchor = index === 0 ? "start" : index === xTicks.length - 1 ? "end" : "middle"

            return `
              <text x="${x}" y="${height - 6}" text-anchor="${anchor}" class="line-chart__label">${xTickDateFormatter.format(new Date(tick))}</text>
            `
          })
          .join("")

        const pathMarkup = hasVisibleSeries
          ? scaledSeries
            .map((series) => {
              const path = series.points
                .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
                .join(" ")

              return `<path d="${path}" class="line-chart__path line-chart__path--series-${series.seriesIndex}" />`
            })
            .join("")
          : chart.showMovingAverage
            ? `
              <path d="${rawPath}" class="line-chart__path line-chart__path--raw" />
              <path d="${displayPath}" class="line-chart__path line-chart__path--average" />
            `
            : `<path d="${displayPath}" class="line-chart__path" />`

        const legendMarkup = hasVisibleSeries
          ? scaledSeries
            .map(
              (series) => `
                <g class="line-chart__legend" transform="translate(${margin.left + series.seriesIndex * 88}, 12)">
                  <line x1="0" y1="0" x2="14" y2="0" class="line-chart__legend-line line-chart__path--series-${series.seriesIndex}" />
                  <text x="18" y="3" class="line-chart__legend-label">${series.label}</text>
                </g>
              `,
            )
            .join("")
          : ""

        const dotMarkup = hasVisibleSeries
          ? scaledSeries
            .map(
              (series) =>
                `<circle cx="0" cy="0" r="3" class="line-chart__dot line-chart__dot--series-${series.seriesIndex}" visibility="hidden" />`,
            )
            .join("")
          : `<circle cx="0" cy="0" r="3" class="line-chart__dot" visibility="hidden" />`

        svg.setAttribute("viewBox", `0 0 ${width} ${height}`)
        svg.innerHTML = `
          ${yTickMarkup}
          ${xTickMarkup}
          ${legendMarkup}
          ${pathMarkup}
          <line x1="0" y1="0" x2="0" y2="0" class="line-chart__crosshair" visibility="hidden" />
          ${dotMarkup}
          <rect x="${margin.left}" y="${margin.top}" width="${plotWidth}" height="${plotHeight}" class="line-chart__overlay" />
        `

        const crosshair = svg.querySelector<SVGLineElement>(".line-chart__crosshair")
        const dots = Array.from(svg.querySelectorAll<SVGCircleElement>(".line-chart__dot"))
        const overlay = svg.querySelector<SVGRectElement>(".line-chart__overlay")

        if (!crosshair || dots.length === 0 || !overlay) {
          throw new Error(`Line chart ${chart.id} interactive layer could not be initialized`)
        }

        const hideTooltip = (): void => {
          crosshair.setAttribute("visibility", "hidden")
          for (const dot of dots) {
            dot.setAttribute("visibility", "hidden")
          }
          tooltip.hidden = true
        }

        const showTooltipFromClientX = (clientX: number): void => {
          const rect = svg.getBoundingClientRect()
          const pointerX = ((clientX - rect.left) / rect.width) * width

          if (pointerX < margin.left || pointerX > width - margin.right) {
            hideTooltip()
            return
          }

          const tooltipPoints = hasVisibleSeries ? scaledSeries[0].points : points
          const closestPointIndex = findClosestPointIndex(tooltipPoints, pointerX)
          const point = tooltipPoints[closestPointIndex]

          crosshair.setAttribute("x1", String(point.x))
          crosshair.setAttribute("y1", String(margin.top))
          crosshair.setAttribute("x2", String(point.x))
          crosshair.setAttribute("y2", String(height - margin.bottom))
          crosshair.setAttribute("visibility", "visible")

          const formattedDate = tooltipDateFormatter.format(new Date(point.timestamp))
          const tooltipPadding = 10

          if (hasVisibleSeries) {
            const seriesPoints = scaledSeries.map((series) => ({
              ...series,
              point: series.points[findClosestPointIndex(series.points, point.x)],
            }))

            for (const [index, series] of seriesPoints.entries()) {
              const dot = dots[index]
              if (!dot) continue
              dot.setAttribute("cx", String(series.point.x))
              dot.setAttribute("cy", String(series.point.y))
              dot.setAttribute("visibility", "visible")
            }

            tooltip.classList.add("line-chart__tooltip--series")
            tooltip.hidden = false
            tooltip.innerHTML = ""
            tooltip.style.left = "0"
            tooltip.style.top = "0"

            for (const series of seriesPoints) {
              const box = document.createElement("div")
              box.className = `line-chart__tooltip-box line-chart__tooltip-box--series-${series.seriesIndex}`
              box.textContent = `${formattedDate} · ${series.label} ${formatValue(series.point.value, chart, "tooltip")}`
              tooltip.append(box)

              const maxLeft = width - box.offsetWidth - tooltipPadding
              const boxLeft = Math.min(maxLeft, Math.max(tooltipPadding, series.point.x - box.offsetWidth / 2))
              const boxTop = Math.max(tooltipPadding, series.point.y - 28)
              box.style.left = `${boxLeft}px`
              box.style.top = `${boxTop}px`
            }
            return
          }

          const dot = dots[0]
          dot.setAttribute("cx", String(point.x))
          dot.setAttribute("cy", String(point.y))
          dot.setAttribute("visibility", "visible")

          tooltip.classList.remove("line-chart__tooltip--series")

          if (chart.showMovingAverage) {
            const rawValue = "rawValue" in point && typeof point.rawValue === "number"
              ? point.rawValue
              : point.value
            tooltip.textContent =
              `${formattedDate} · MA${chart.movingAverageWindowDays} ${formatValue(point.value, chart, "tooltip")} · Raw ${formatValue(rawValue, chart, "tooltip")}`
          } else {
            tooltip.textContent = `${formattedDate} · ${formatValue(point.value, chart, "tooltip")}`
          }

          tooltip.hidden = false

          const tooltipHalfWidth = tooltip.offsetWidth / 2
          const minLeft = tooltipPadding
          const maxLeft = width - tooltip.offsetWidth - tooltipPadding
          const tooltipLeft = Math.min(maxLeft, Math.max(minLeft, point.x - tooltipHalfWidth))
          const tooltipTop = Math.max(tooltipPadding, point.y - 28)

          tooltip.style.left = `${tooltipLeft}px`
          tooltip.style.top = `${tooltipTop}px`
        }

        overlay.addEventListener("pointermove", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerdown", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerleave", hideTooltip)
        overlay.addEventListener("pointercancel", hideTooltip)
        overlay.addEventListener("pointerup", (e) => {
          if (e.pointerType === "touch") {
            hideTooltip()
          }
        })
      }

      function renderAllCharts(): void {
        for (const chart of charts) {
          renderChart(chart)
        }
      }

      type ParsedStatCard = {
        node: HTMLElement
        data: LineChartPoint[]
        format: LineChartFormat
        formatScale: number
        formatPrefix: string
        formatSuffix: string
        percentMode: PercentMode
        showMovingAverage: boolean
      }

      function parseMetricNode(node: HTMLElement, label: string): ParsedStatCard {
        const x = node.dataset.x
        const y = node.dataset.y
        const chartId = node.dataset.chartId

        if (!chartId || !x || !y) {
          throw new Error(`${label} is missing required dataset attributes`)
        }

        const xColumn = dataset[x]
        const yColumn = dataset[y]

        if (!xColumn || !yColumn) {
          throw new Error(`${label} ${chartId} references missing columns`)
        }

        const data: LineChartPoint[] = []

        for (let i = 0; i < xColumn.length; i++) {
          const rawX = xColumn[i]
          const rawY = yColumn[i]
          if (rawX == null || rawY == null) continue
          const timestamp = toTimestamp(chartId, rawX)
          const value = Number(rawY)
          if (!Number.isFinite(value)) continue
          data.push({ timestamp, value })
        }

        return {
          node,
          data,
          format: parseFormat(node.dataset.format),
          formatScale: parsePositiveNumber(node.dataset.formatScale, 1),
          formatPrefix: node.dataset.formatPrefix ?? "",
          formatSuffix: node.dataset.formatSuffix ?? "",
          percentMode: parsePercentMode(node.dataset.percentMode),
          showMovingAverage: node.dataset.showMovingAverage === "true",
        }
      }

      const statCardNodes = Array.from(document.querySelectorAll<HTMLElement>(STAT_CARD_SELECTOR))
      const statCards = statCardNodes.map((node) => parseMetricNode(node, "Stat card"))
      const componentSparkNodes = Array.from(document.querySelectorAll<HTMLElement>(COMPONENT_SPARK_SELECTOR))
      const componentSparks = componentSparkNodes.map((node) => parseMetricNode(node, "Component spark"))

      function renderStatCard(card: ParsedStatCard): void {
        const points = getPointsForRange(card.data, currentRange)
        const valueEl = card.node.querySelector<HTMLElement>("[data-stat-card-value]")
        const trendEl = card.node.querySelector<HTMLElement>("[data-stat-card-trend]")
        const svg = card.node.querySelector<SVGElement>(".stat-card__spark")

        if (!valueEl || !trendEl || !svg) return
        if (points.length < 2) {
          valueEl.textContent = "—"
          trendEl.textContent = ""
          svg.innerHTML = ""
          return
        }

        const rawValues = points.map((p) => p.value)
        const series = card.showMovingAverage ? buildMovingAverage(rawValues, 30) : rawValues
        const latest = series[series.length - 1]
        const compareIndex = Math.max(0, series.length - 1 - 30)
        const prev = series[compareIndex]

        valueEl.textContent = formatValue(latest, card, "headline")

        const pctChange = prev !== 0 ? ((latest - prev) / prev) * 100 : 0
        const sign = pctChange > 0 ? "+" : ""
        const trend = pctChange > 0 ? "▲" : pctChange < 0 ? "▼" : "■"
        trendEl.textContent = `${trend} ${sign}${formatDecimal(pctChange, 2)}% 30d`

        // Sparkline
        const width = card.node.clientWidth
        const height = 48
        const pad = 2

        const minX = points[0].timestamp
        const maxX = points[points.length - 1].timestamp
        const minY = Math.min(...series)
        let maxY = Math.max(...series)
        if (maxY === minY) maxY = minY + 1

        const sx = (t: number) => pad + ((t - minX) / Math.max(maxX - minX, DAY_IN_MS)) * (width - pad * 2)
        const sy = (v: number) => pad + ((maxY - v) / (maxY - minY)) * (height - pad * 2)

        const d = series.map((v, i) => `${i === 0 ? "M" : "L"} ${sx(points[i].timestamp)} ${sy(v)}`).join(" ")

        svg.setAttribute("viewBox", `0 0 ${width} ${height}`)
        svg.innerHTML = `<path d="${d}" fill="none" stroke="var(--color-border-strong)" stroke-width="1.5" />`
      }

      function renderAllStatCards(): void {
        for (const card of statCards) {
          renderStatCard(card)
        }
      }

      function renderComponentSpark(card: ParsedStatCard): void {
        const points = getPointsForRange(card.data, currentRange)
        const valueEl = card.node.querySelector<HTMLElement>("[data-component-spark-value]")
        const svg = card.node.querySelector<SVGElement>(".stat-card__detail-spark")
        const tooltip = card.node.querySelector<HTMLDivElement>("[data-component-spark-tooltip]")

        if (!valueEl || !svg || !tooltip) return
        if (points.length < 2) {
          valueEl.textContent = "—"
          svg.innerHTML = ""
          tooltip.hidden = true
          return
        }

        const latest = points[points.length - 1].value
        valueEl.textContent = formatValue(latest, card, "headline")

        const width = Math.max(180, card.node.clientWidth)
        const height = 88
        const margin = { top: 8, right: 4, bottom: 18, left: 4 }
        const plotWidth = width - margin.left - margin.right
        const plotHeight = height - margin.top - margin.bottom
        const values = points.map((point) => point.value)
        const minX = points[0].timestamp
        const maxX = points[points.length - 1].timestamp
        const dataMinY = Math.min(...values)
        const minY = dataMinY >= 0 ? 0 : dataMinY
        let maxY = Math.max(...values)
        if (maxY === minY) maxY = minY + 1
        maxY += (maxY - minY) * 0.08

        const sx = (t: number) => margin.left + ((t - minX) / Math.max(maxX - minX, DAY_IN_MS)) * plotWidth
        const sy = (v: number) => margin.top + ((maxY - v) / (maxY - minY)) * plotHeight
        const chartPoints = points.map((point) => ({ ...point, x: sx(point.timestamp), y: sy(point.value) }))
        const d = chartPoints.map((point, i) => `${i === 0 ? "M" : "L"} ${point.x} ${point.y}`).join(" ")
        const yTicks = buildTicks(minY, maxY, 3)
          .map((tick) => {
            const y = sy(tick)
            return `<line x1="${margin.left}" y1="${y}" x2="${width - margin.right}" y2="${y}" class="line-chart__gridline" />`
          })
          .join("")

        svg.setAttribute("viewBox", `0 0 ${width} ${height}`)
        svg.innerHTML = `
          ${yTicks}
          <path d="${d}" class="line-chart__path" />
          <line x1="0" y1="0" x2="0" y2="0" class="line-chart__crosshair" visibility="hidden" />
          <circle cx="0" cy="0" r="3" class="line-chart__dot" visibility="hidden" />
          <rect x="${margin.left}" y="${margin.top}" width="${plotWidth}" height="${plotHeight}" class="line-chart__overlay" />
        `

        const crosshair = svg.querySelector<SVGLineElement>(".line-chart__crosshair")
        const dot = svg.querySelector<SVGCircleElement>(".line-chart__dot")
        const overlay = svg.querySelector<SVGRectElement>(".line-chart__overlay")
        if (!crosshair || !dot || !overlay) return

        const hideTooltip = (): void => {
          crosshair.setAttribute("visibility", "hidden")
          dot.setAttribute("visibility", "hidden")
          tooltip.hidden = true
        }

        const showTooltipFromClientX = (clientX: number): void => {
          const rect = svg.getBoundingClientRect()
          const pointerX = ((clientX - rect.left) / rect.width) * width
          const closestPointIndex = findClosestPointIndex(chartPoints, pointerX)
          const point = chartPoints[closestPointIndex]

          crosshair.setAttribute("x1", String(point.x))
          crosshair.setAttribute("y1", String(margin.top))
          crosshair.setAttribute("x2", String(point.x))
          crosshair.setAttribute("y2", String(height - margin.bottom))
          crosshair.setAttribute("visibility", "visible")
          dot.setAttribute("cx", String(point.x))
          dot.setAttribute("cy", String(point.y))
          dot.setAttribute("visibility", "visible")

          tooltip.textContent = `${tooltipDateFormatter.format(new Date(point.timestamp))} · ${formatValue(point.value, card, "tooltip")}`
          tooltip.hidden = false
          tooltip.style.left = `${Math.min(width - tooltip.offsetWidth - 4, Math.max(4, point.x - tooltip.offsetWidth / 2))}px`
          tooltip.style.top = `${Math.max(4, point.y - 28)}px`
        }

        overlay.addEventListener("pointermove", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerdown", (e) => showTooltipFromClientX(e.clientX))
        overlay.addEventListener("pointerleave", hideTooltip)
        overlay.addEventListener("pointercancel", hideTooltip)
      }

      function renderAllComponentSparks(): void {
        for (const card of componentSparks) {
          renderComponentSpark(card)
        }
      }

      const observers: ResizeObserver[] = charts.map((chart) => {
        const observer = new ResizeObserver(() => {
          renderChart(chart)
        })

        observer.observe(chart.node)
        return observer
      })

      for (const card of statCards) {
        const observer = new ResizeObserver(() => renderStatCard(card))
        observer.observe(card.node)
        observers.push(observer)
      }

      for (const card of componentSparks) {
        const observer = new ResizeObserver(() => renderComponentSpark(card))
        observer.observe(card.node)
        observers.push(observer)
      }

      const rangeButtons = document.querySelectorAll<HTMLButtonElement>(RANGE_BUTTON_SELECTOR)

      for (const button of rangeButtons) {
        button.addEventListener("click", () => {
          const range = button.dataset.lineChartRange

          if (range !== "6m" && range !== "1y" && range !== "all") {
            return
          }

          if (range === currentRange) {
            return
          }

          currentRange = range
          updateRangeButtons(currentRange)
          updateUrlState()
          renderAllCharts()
          renderAllStatCards()
          renderAllComponentSparks()
        })
      }

      for (const chart of charts) {
        const handleToggle = (event: Event): void => {
          event.preventDefault()
          setExpandedChart(expandedChartId === chart.id ? null : chart.id, {
            scrollIntoView: expandedChartId !== chart.id,
          })
        }

        chart.node.addEventListener("click", (event: Event) => {
          const target = event.target as HTMLElement
          if (target.closest(".line-chart__tooltip, .line-chart__svg")) {
            return
          }
          handleToggle(event)
        })
      }

      const onKeyDown = (event: KeyboardEvent): void => {
        if (event.key !== "Escape" || expandedChartId === null) {
          return
        }

        setExpandedChart(null)
      }

      document.addEventListener("keydown", onKeyDown)

      updateRangeButtons(currentRange)
      syncExpandedChartState()
      updateUrlState()
      renderAllCharts()
      renderAllStatCards()
      renderAllComponentSparks()

      if (expandedChartId) {
        requestAnimationFrame(() => {
          scrollChartIntoView(expandedChartId)
        })
      }

      window.addEventListener(
        "pagehide",
        () => {
          document.removeEventListener("keydown", onKeyDown)

          for (const observer of observers) {
            observer.disconnect()
          }
        },
        { once: true },
      )
    }
  </script>
</Layout>
