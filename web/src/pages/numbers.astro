        format: "percent",
      },
      {
        id: "active-sectors",
        title: "Active Sectors",
        y: "active_sector_count",
        format: "integer",
      },
    ],
  },
  {
    id: "activity",
    title: "Activity",
    charts: [
      {
        id: "active-addresses",
        title: "Active Addresses",
        y: "active_address_count_daily",
        format: "integer",
      },
      {
