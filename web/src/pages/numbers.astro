import SectionHeading from "../components/SectionHeading.astro"
import StatCard from "../components/StatCard.astro"
import Layout from "../layouts/Layout.astro"

type DatasetValue = string | number | null
type DatasetRow = Record<string, DatasetValue>
type MetricFormat =
  | "integer"
  | "number"
  | "pib"
  | "fil"
  | "mfil"
  | "usd"
  | "percent"
type ChartRange = "6m" | "1y" | "all"
type RangeValues<T> = Record<ChartRange, T>
type ChartPoint = [timestamp: number, value: number]
type ChartConfig = {
  y: string
  format: MetricFormat
  scale?: number
  suffix?: string
  series?: { label: string; y: string }[]
}
type NumbersMetric = ChartConfig & {
  id: string
  title: string
  description: string
  details?: (ChartConfig & { title: string; description: string })[]
}
type NumbersSection = {
  id: string
  title: string
  columns: 2 | 3 | 4
  charts: NumbersMetric[]
}
type MetricSummary = {
  value: string
  trend: string
  rangeLabels: RangeValues<string>
  sparklinePaths: RangeValues<string>
  accessibleSummary: string
}

